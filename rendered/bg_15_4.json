      "senses_attested_in_panel": [
        {
          "sense": "इत्येवं परिमार्गितव्यं तच्छरणतया इत्यर्थः",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "तम् एव शरणं प्रपद्येत। यतः यस्मात् कृत्स्नस्य स्रष्टुः इयं गुणमयभोगसङ्ग प्रवृत्तिः पुराणी पुरातनी प्रसृता। उक्तं हि मया",
