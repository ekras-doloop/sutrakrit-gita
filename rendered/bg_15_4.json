          "weight": 0.8,
          "witnesses": [
            "madhva"
          ]
        },
        {
          "sense": "शरणं व्रजामीत्येवमेकान्तभक्त्यान्वेष्टव्यमित्यर्थः",
          "school": "bhakti",
          "weight": 0.8,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "शरणं गतोऽस्मीत्येवं तदेकशरणतया तदन्वेष्टव्यमित्यर्थः",
