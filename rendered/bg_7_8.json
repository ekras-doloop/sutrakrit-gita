{
  "verse_id": "7.8",
  "mūla": {
    "devanāgarī": "रसो ऽहम् अप्सु कौन्तेय प्रभास्मि शशि-सूर्ययोः | प्रणवः सर्व-वेदेषु शब्दः खे पौरुषं नृषु",
    "iast": "raso 'ham apsu kaunteya prabhāsmi śaśi-sūryayoḥ | praṇavaḥ sarva-vedeṣu śabdaḥ khe pauruṣaṃ nṛṣu",
    "chapter_position": "Chapter 7 (Jñāna-Vijñāna-Yoga (The Yoga of Knowledge and Realization)), verse 8",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
