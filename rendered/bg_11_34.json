      "senses_attested_in_panel": [
        {
          "sense": "जेतासि दुर्योधनप्रभृतीन् रणे युद्धे सपत्नान् शत्रून्",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "? रणे सपत्नान् जेतासि? जेष्यसि? न एतेषां वधे नृशंसतागन्धः?",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। जेतासि जेष्यस्यचिरेणैव रणे संग्रामे सपत्नान् सर्वानपि शत्रून्। अत्र द्रोणं च भीष्मं च जयद्रथं चेति चकारत्रयेण पूर्वोक्",
          "school": "advaita-bhakti",
          "weight": 0.8,
          "witnesses": [
            "madhusudan"
