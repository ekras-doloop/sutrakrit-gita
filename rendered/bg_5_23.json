      "grammar": "3rd person singular present indicative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "उत्सहते इहैव जीवन्नेव",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "स युक्तः आत्मानुभवाय अर्हः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "। शरीरविमोक्षणात्प्राक्। यथा मनुष्यशरीरे सोढुं सुशकः तथा नान्यत्रेति भावः। ब्रह्मलोकादिस्तु जितकामानामेव भवति।",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "madhva"
          ]
        },
        {
          "sense": "सोद्वापि न मोक्षसाधनं त्यजति स ज्ञातव्यो योगी युक्तो ब्रह्मानन्दवांश्च अन्यथा तु गत शरीरे सिद्धमेवेति न पुरुषकारः स्यात",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "। तदपि न क्षणमात्रं किंतु शरीरविमोक्षणात्प्राक्। यावद्देहपातमित्यर्थः। य एवंभूतः स एव मुक्तः समाहितः सुखी च भवति नान्यः।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "समर्थो भवति स",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
