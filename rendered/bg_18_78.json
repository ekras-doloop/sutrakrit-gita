      "senses_attested_in_panel": [
        {
          "sense": "यस्मिन् पक्षे योगेश्वरः सर्वयोगानाम् ईश्वरः? तत्प्रभवत्वात् सर्वयोगबीजस्य? कृष्णः?",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "योगेश्वरः कृत्स्नस्य उच्चावचरूपेण अवस्थितस्य चेतनस्य अचेतनस्य",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति। यत्र योगेश्वरः कृष्णः? यत्र पार्थो धनुर्धरः? तत्र श्रीः राज्यलक्ष्मीः? विजयो ध्रुवा निश्चिता नीतिः? अन्यत्रैवं न? भ",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ेति। यत्र येषां पाण्डवानां पक्षे योगेश्वरः श्रीकृष्णो वर्तते? यत्र च पार्थो गाण्डीवधनुर्धरः तत्रैव श्री राज्यलक्ष्मीः? त",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ेति। यत्र यस्मिन् युधिष्ठिरपक्षे योगेश्वरः सर्वयोगसिद्धीनामीश्वरः सर्वज्ञः सर्वशक्तिर्भगवान्कृष्णो भक्तदुःखकर्षणस्तिष्ठत",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
