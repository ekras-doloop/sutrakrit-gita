{
  "verse_id": "7.1",
  "mūla": {
    "devanāgarī": "मय्य् आसक्तमनाः पार्थ योगं युञ्जन् मदाश्रयः | असंशयं समग्रं मां यथा ज्ञास्यसि तच् छृणु",
    "iast": "mayy āsaktamanāḥ pārtha yogaṃ yuñjan madāśrayaḥ | asaṃśayaṃ samagraṃ māṃ yathā jñāsyasi tac chṛṇu",
    "chapter_position": "Chapter 7 (Jñāna-Vijñāna-Yoga (The Yoga of Knowledge and Realization)), verse 1",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
