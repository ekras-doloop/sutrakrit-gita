      "grammar": "locative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "एव विश्वरूपे ईश्वरे मनः संकल्पविकल्पात्मकं आधत्स्व स्थापय। मयि एव अध्यवसायं कुर्वतीं बुद्धिम् आधत्स्व निवेशय। ततः ते कि",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "एव मन आधत्स्व -- मयि मनः समाधानं कुरु? मयि बुद्धिं निवेशय -- अहम् एव परमप्राप्य इति अध्यवसायं कुरु। अत ऊर्ध्वं मयि एव न",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        }
      ],
