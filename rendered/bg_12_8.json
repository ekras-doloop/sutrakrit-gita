{
  "verse_id": "12.8",
  "mūla": {
    "devanāgarī": "मय्य् एव मन आधत्स्व मयि बुद्धिं निवेशय | निवसिष्यसि मय्य् एव अत ऊर्ध्वं न संशयः",
    "iast": "mayy eva mana ādhatsva mayi buddhiṃ niveśaya | nivasiṣyasi mayy eva ata ūrdhvaṃ na saṃśayaḥ",
    "chapter_position": "Chapter 12 (Bhakti-Yoga (The Yoga of Devotion)), verse 8",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
