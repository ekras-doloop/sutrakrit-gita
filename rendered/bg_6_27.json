      "senses_attested_in_panel": [
        {
          "sense": "तद्वृत्त्योरभावे स्वरूपभूतसुखाविर्भावस्य स्वापादौ प्रसिद्धिं द्योतयितुं हिशब्दः",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "कम्। निर्मनस्कत्वे हेतुगर्भं विशेषणद्वयं शान्तरजसमकल्मषमिति। शान्तं विक्षेपकं रजो यस्य तं विक्षेपशून्यम्। तथा न विद्यते",
          "school": "advaita-bhakti",
          "weight": 1.0,
