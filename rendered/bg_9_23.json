      "grammar": "3rd person plural present indicative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "पूजयन्ति श्रद्धया आस्तिक्यबुद्ध्या अन्विताः अनुगताः? तेऽपि मामेव कौन्तेय यजन्ति अविधिपूर्वकम् अविधिः अज्ञानं तत्पूर्वकं",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "? तेऽपि पूर्वोक्तेन न्यायेन सर्वस्य मच्छरीरतया मदात्मत्वेन इन्द्रादिशब्दानां",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। अपित्वविधिपूर्वकं तेषामात्मभूतमधिष्ठानताज्ञानपूर्वकं यजनं वेदे विहितम् इतरथा त्वविहितमित्यविधिपूर्वकं ते यजन्ते ततो गत",
          "school": "śuddhādvaita",
          "weight": 0.8,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "तेऽपि मामेव यजन्तीति सत्यम्? किंत्वविधिपूर्वकं मोक्षप्रापकं विधिं विना यजन्त्यतस्ते पुनरावर्तन्ते",
          "school": "bhakti",
          "weight": 0.8,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ज्योतिष्टोमादिभिः श्रद्धया आस्तिक्यबुद्ध्या अन्विताः तेऽपि मद्भक्ता",
          "school": "advaita-bhakti",
          "weight": 0.8,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
