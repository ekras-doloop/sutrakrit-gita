      "senses_attested_in_panel": [
        {
          "sense": "आस्तिक्यबुद्ध्या अन्विताः अनुगताः? तेऽपि मामेव कौन्तेय यजन्ति अविधिपूर्वकम् अविधिः अज्ञानं तत्पूर्वकं यजन्ते इत्यर्थः",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "अन्विताः इन्द्रादीन् यजन्ते? तेऽपि पूर्वोक्तेन न्यायेन सर्वस्य मच्छरीरतया मदात्मत्वेन इन्द्रादिशब्दानां",
          "school": "viśiṣṭādvaita",
