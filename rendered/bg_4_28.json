  "mūla": {
    "devanāgarī": "द्रव्य-यज्ञास् तपो-यज्ञा योग-यज्ञास् तथापरे | स्वाध्याय-ज्ञान-यज्ञाश् च यतयः संशित-व्रताः",
    "iast": "dravya-yajñās tapo-yajñā yoga-yajñās tathāpare | svādhyāya-jñāna-yajñāś ca yatayaḥ saṃśita-vratāḥ",
    "chapter_position": "Chapter 4 (Jñāna-Karma-Sannyāsa-Yoga (The Yoga of Renunciation of Action in Knowledge)), verse 28",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
