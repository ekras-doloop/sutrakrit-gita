          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ं जुह्वतीति द्रव्ययज्ञाः",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "यज्ञाः इति गृहिणो निरूपिताः तपोयज्ञा वनस्थाश्च",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ेति। द्रव्यदानमेव यज्ञो येषां ते द्रव्ययज्ञाः। कृच्छ्रचान्द्रायणादितप एव यज्ञो येषां ते तपोयज्ञाः। योगश्चित्तवृत्तिनिरोध",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "त्याग एव यथाशास्त्रं यज्ञो येषां ते द्रव्ययज्ञाः पूर्तदत्ताख्यरूपस्मार्तकर्मपराः। तथाच स्मृतिःवापीकूपतडागादि देवतायतनानि",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
