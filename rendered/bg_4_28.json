        {
          "sense": "ोयज्ञाः तपः यज्ञः येषां तपस्विनां ते तपोयज्ञाः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ोयज्ञाः कृच्छ्रचान्द्रायणोपवासादिषु निष्ठां कुर्वन्ति योगयज्ञाः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ः परमेश्वरार्पणबुद्ध्या तत्र जुह्वतीति तपोयज्ञा इत्यादि",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "ोयज्ञा वनस्थाश्च",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "एव यज्ञो येषां ते तपोयज्ञाः। योगश्चित्तवृत्तिनिरोधलक्षणः समाधिः स एव यज्ञो येषां ते योगयज्ञाः। स्वाध्यायेन वेदेन श्रवणम",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "एव यज्ञो येषां ते तपोयज्ञास्तपस्विनः। तथा योगश्चित्तवृत्तिनिरोधोऽष्टाङ्गो यज्ञो येषां ते योगयज्ञा यमनियमासनादियोगाङ्गान",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
