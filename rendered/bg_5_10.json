    {
      "surface_form": "ādhāya",
      "lemma": "ādhā",
      "grammar": "dative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "निक्षिप्य तदर्थं कर्म करोमि इति भृत्य इव स्वाम्यर्थं सर्वाणि कर्माणि मोक्षेऽपि फले सङ्गं त्यक्त्वा करोति",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "फल सङ्गं त्यक्त्वा नैव किञ्चित् करोमि इति",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "समर्प्य सङ्गं फलाभिलाषं त्यक्त्वेश्वरार्थं भृत्यइव स्वाम्यर्थं स्वफलनिरपेक्षतया करोमीत्यभिप्रायेण कर्माणि लौकिकानि वैदि",
          "school": "advaita-bhakti",
          "weight": 0.8,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
