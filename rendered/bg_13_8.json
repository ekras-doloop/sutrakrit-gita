      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "कस्य आत्मशब्दवाच्यस्य कार्यकरणसंघातस्य विनिग्रहः स्वभावेन सर्वतः प्रवृत्तस्य सन्मार्गे",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ः अनात्मनि देहे आत्माभिमानरहितत्वम्? प्रदर्शनार्थम् इदम्? अनात्मीयेषु आत्मीयाभिमानरहित्वं",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ाभ्यां दम्भं पृथक् दर्शयति -- आत्मे ति",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "हेतौ,प्राप्तेऽपि निर्विकारचित्ततया तदपराधसहनं क्षान्तिः",
          "school": "advaita-bhakti",
          "weight": 1.0,
