      "senses_attested_in_panel": [
        {
          "sense": "ार्योपासनं मोक्षसाधनोपदेष्टुः आचार्यस्य शुश्रूषादिप्रयोगेण सेवनम्",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "अपिविवक्षितम्",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "यो यत्प्रभावश्च इति वक्तुं तज्ज्ञानसाधनान्याह -- अमानित्वमित्यादिना। आत्माल्पत्वं ज्ञात्वाऽपि महत्त्वप्रदर्शनं दम्भः।ज्",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "तुर्भिः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "भिः। अमानित्वं स्वगुणश्लाघाराहित्यम्? अदम्भित्वं दम्भराहित्यम्? अहिंसा परपीडावर्जनम्? क्षान्तिः सहिष्णुत्वम्?,आर्जवमवक्र",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "भिः -- अमानित्वमित्यादिना",
          "school": "advaita-bhakti",
          "weight": 1.0,
