      "senses_attested_in_panel": [
        {
          "sense": "ेति। प्रत्येकं दोषानुदर्शनमित्युक्तं तत्र जन्मनि दोषानुदर्शनं विशदयति -- जन्मनीति। यथा जन्मनि दोषानुसंधानं तथा मृत्यौ दो",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "मृत्युजराव्याधिदुःखदोषानुदर्शनम् -- सशरीरत्वे जन्ममृत्युजराव्याधिदुःखस्वरूपस्य दोषस्य अवर्जनीयत्वानुसंधानम्",
