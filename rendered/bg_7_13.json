      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "मयैः गुणविकारैः रागद्वेषमोहादिप्रकारैः भावैः पदार्थैः एभिः यथोक्तैः सर्वम् इदं प्राणिजातं जगत् मोहितम् अविवेकितामापादितं",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "गणैः च अहम् एव सर्वैः प्रकारैः परतरः। मत्तः अन्यत् केन अपि कल्याणगुणगणेन परतरं न विद्यते। एवंभूतं मां त्रिभ्यः सात्त्विक",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
