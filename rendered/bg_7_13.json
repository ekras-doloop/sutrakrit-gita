{
  "verse_id": "7.13",
  "mūla": {
    "devanāgarī": "त्रिभिर् गुण-मयैर् भावैर् एभिः सर्वम् इदं जगत् | मोहितं नाभिजानाति माम् एभ्यः परम् अव्ययम्",
    "iast": "tribhir guṇa-mayair bhāvair ebhiḥ sarvam idaṃ jagat | mohitaṃ nābhijānāti mām ebhyaḥ param avyayam",
    "chapter_position": "Chapter 7 (Jñāna-Vijñāna-Yoga (The Yoga of Knowledge and Realization)), verse 13",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
