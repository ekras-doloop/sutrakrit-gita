      "senses_attested_in_panel": [
        {
          "sense": "तु बहिर्मुखः कामकारेण कामतः प्रवृत्त्या फले आसक्तो नितरां बन्धं प्राप्नोति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "karma",
      "lemma": "karman",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "ाणि करोमि न मम फलाय इत्येवं समाहितः सन् कर्मफलं त्यक्त्वा परित्यज्य शान्तिं मोक्षाख्याम् आप्नोति नैष्ठिकीं निष्ठायां भवा",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "फलं त्यक्त्वा केवलात्मशुद्धये कर्मानुष्ठाय नैष्ठिकीं शान्तिम् आप्नोति स्थिराम् आत्मानुभवरूपां निर्वृतिम् आप्नोति",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "करणे मोक्षं विपरीते बन्धनं चाह युक्त इति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "णा कश्चिन्मुच्यते कश्चिद्बध्यत इति व्यवस्था कथमत आह युक्त इति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "णा कश्चिन्मुच्यते कश्चित्तु बध्यत इति वैषम्ये को",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
