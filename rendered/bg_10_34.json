      "senses_attested_in_panel": [
        {
          "sense": "थानादि निमित्तोपादानादिकं चात्र पृथगेव निर्दिष्टमिति क्रियापरत्वमेवोचितमित्यभिप्रायेणउद्भवाख्यं कर्मेत्युक्तम्",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        }
