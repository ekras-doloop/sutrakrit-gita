        },
        {
          "sense": "उत्पत्स्यमानानाम् उद्भवाख्यं कर्म",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। अथवा कीर्त्तिर्वृषभानुपत्नी मद्विभूतिः। तत्र श्रीश्चाहम्। वाक्सरस्वतीयमवताररूपा चाहं श्रीपरिचारिका वा निर्दिष्टा।",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "। भविष्यतां भाविकल्याणानां प्राणिनामुद्भवोऽभ्युदयोऽहम्। नारीणां स्त्रीणां मध्ये कीर्त्याद्याः सप्त देवतारूपाः स्त्रियोऽह",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "। भविष्यतां भाविकल्याणानां य उद्भव उत्कर्षः स चाहमेव। नारीणां मध्ये कीर्तिः श्रीर्वाक् स्मृतिर्मेधा धृतिः क्षमेति च सप्त",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
