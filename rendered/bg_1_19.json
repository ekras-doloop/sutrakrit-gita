{
  "verse_id": "1.19",
  "mūla": {
    "devanāgarī": "स घोषो धार्तराष्ट्राणां हृदयानि व्यदारयत् | नभश् च पृथिवीं चैव तुमुलो व्यनुनादयन्",
    "iast": "sa ghoṣo dhārtarāṣṭrāṇāṃ hṛdayāni vyadārayat | nabhaś ca pṛthivīṃ caiva tumulo vyanunādayan",
    "chapter_position": "Chapter 1 (Arjuna-Viṣāda-Yoga (The Yoga of Arjuna's Despondency)), verse 19",
    "speaker": "Arjuna",
    "addressed_to": "Krishna"
  },
  "word_by_word": [
    {
      "surface_form": "sa",
      "lemma": "sa",
      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "्तै राजभिः शङ्खानापूरयद्भिरापादितो महान्घोषस्तुमुलोऽतिभैरवो नभश्चान्तरिक्षं पृथिवीं",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "ञ्जय उवाच दुर्योधनः स्वयमेव भीमाभिरक्षितं पाण्डवानां बलम् आत्मीयं",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "घोषः दुर्योधनादिहृदयानि बिभेद",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "च शङ्खानां नादस्त्वदीयानां महाभयं जनयामासेत्याह स घोष इति। धार्तराष्ट्राणां त्वदीयानां हृदयानि विदारितवान्। किं कुर्वन्",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ैन्ये शङ्खादिध्वनिरतितुमुलोऽपि न पाण्डावानां क्षोभकोऽभूत् पाण्डवानां सैन्ये जातस्तु स शङ्खघोषो धार्तराष्ट्राणां धृतराष्ट",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "gha",
      "lemma": "gha",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "ोषस्तुमुलोऽतिभैरवो नभश्चान्तरिक्षं पृथिवीं",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
