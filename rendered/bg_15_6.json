        {
          "sense": "धाम इति व्यवहितेन धाम्ना संबध्यते",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "परमं धाम परमं ज्योतिः मम मदीयं मद्विभूतिभूतो ममांश इत्यर्थः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "पदं यत्प्राप्तिः पुरुषार्थः। इत्याकाङ्क्षायामिदमुच्यत इत्युक्तं भवति। स्वरूपमित्यनेन पदमित्युक्तस्य धामेति वक्ष्यमाणस्य",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "परमं सर्वोत्कृष्टं मम पुरुषोत्तमस्य धाम परमं ज्योतीरूपं सर्वप्रकाशकं अध्यात्मज्ञानस्वरूपंन",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
