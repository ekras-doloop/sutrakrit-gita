      "lemma": "tad",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "ज्ञेयं भूतभर्तृ",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "च ज्ञानगम्यम् अमानित्वादिभिः उक्तैः ज्ञानसाधनैः प्राप्यम् इत्यर्थः। हृदि सर्वस्य विष्ठितं सर्वस्य मनुष्यादेः हृदि विशेष",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "रापि विचारः -- सति चिदानन्दधर्मयोस्तिरोभावः? चित्यानन्दस्य आनन्दांशतिरोभावस्यापि ज्ञापकं तु निराकारा इति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "पूर्वोक्तं स्वरूपं",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "नतु प्रतिदेहं भिन्नं व्योमवत्सर्वव्यापकत्वात्",
