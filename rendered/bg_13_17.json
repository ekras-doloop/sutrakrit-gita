      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "तद् एव ज्योतिः प्रकाशकम् दीपादित्यादीनाम् अपि आत्मप्रभारूपं ज्ञानम् एव प्रकाशकम्। दीपादयः तु विषयेन्द्रियसन्निकर्षविरोध",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। आनन्दांशस्वरूपेण सर्वान्तर्यामिरूपिणः।।इत्यादि। अस्यार्थः -- बहु स्यामिति अनेकत्वमुच्चनीचत्वं भावयामास। भावना तस्य विष",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        }
      ],
      "theme_lists": []
    },
    {
