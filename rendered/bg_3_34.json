      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "ः अनिष्टे द्वेषः इत्येवं प्रतीन्द्रियार्थं रागद्वेषौ अवश्यंभाविनौ तत्र अयं पुरुषकारस्य शास्त्रार्थस्य",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ः अवर्जनीयो व्यवस्थितः तदनुभवे प्रतिहते",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "मसम्मतिमाह तथाही ति",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "द्वेषावन्तरस्वकृतौ व्यवस्थितौ तदनधीनत्वमेव सिद्धिहेतुरिति अतस्तयोर्न वशमागच्छेत् तौ ह्यस्य परिपन्थिनौ विवेकवित्तस्य कुपथ",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ः प्रतिकूले द्वेषश्चेत्येवं रागद्वेषौ व्यवस्थिताववश्यंभाविनौ",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ः प्रतिकूले शास्त्रविहितेऽपि द्वेष इत्येवं प्रतीन्द्रियार्थं रागद्वेषौ व्यवस्थितावानुकूल्यप्रातिकूल्यव्यवस्थया स्थितौ नत",
          "school": "advaita-bhakti",
