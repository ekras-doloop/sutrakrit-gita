      "senses_attested_in_panel": [
        {
          "sense": "दं द्वारं नाशनम् आत्मनः?",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ति। त्रयाणां स्वरूपं पूर्वम् एव व्याख्यातम्। द्वारं मार्गो हेतुः इत्यर्थः। तस्मात् एतत् त्रयं त्यजेत्। तस्माद् अतिघोरनरक",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "तितस्मादेतत्त्रयं त्यजेत् इति हितोपदेशः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "दं त्रिविधं त्रिप्रकारं नरकस्य प्राप्तौ द्वारं साधनं सर्वस्या आसुर्याः संपदो मूलभूतमात्मनो नाशनं सर्वपुरुषार्थायोग्यतासं",
          "school": "advaita-bhakti",
          "weight": 1.0,
