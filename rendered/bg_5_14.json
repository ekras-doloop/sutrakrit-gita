{
  "verse_id": "5.14",
  "mūla": {
    "devanāgarī": "न कर्तृत्वं न कर्माणि लोकस्य सृजति प्रभुः | न कर्म-फल-संयोगं स्वभावस् तु प्रवर्तते",
    "iast": "na kartṛtvaṃ na karmāṇi lokasya sṛjati prabhuḥ | na karma-phala-saṃyogaṃ svabhāvas tu pravartate",
    "chapter_position": "Chapter 5 (Karma-Sannyāsa-Yoga (The Yoga of Renunciation)), verse 14",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
