      "senses_attested_in_panel": [
        {
          "sense": "पेण विभक्तेषु सर्वेषु भूतेषु कर्माधिकारिषु येन ज्ञानेन एकाकारम् आत्माख्यं भावं तत्र",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "पेण विभक्तेष्वपि कर्माधिकारिषु ब्राह्मणत्वाद्याकारेषु नैकगुणेषु नैकेष्वेकाकारमात्माख्यं भावं तथाप्यव्ययं व्ययस्वभावेष्वप",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "पयति त्रिभिः श्लोकैस्तत्राद्वैतवादिनां सात्त्विकं ज्ञानमाह -- सर्वभूतेष्विति",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
