      "senses_attested_in_panel": [
        {
          "sense": "र चन्द्रमसि भवं चान्द्रमसं ज्योतिः फलम् इष्टादिकारी योगी कर्मी प्राप्य भुक्त्वा तत्क्षयात् इह पुनः निवर्तते",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "च धूमादिमार्गस्थपितृलोकादेः प्रदर्शनम्। अत्र योगिशब्द पुण्यकर्मसम्बन्धिविषयः।",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "र प्रयातः कर्मयोगी चान्द्रमसं ज्योतिस्तदुपलक्षितं स्वर्गलोकं प्राप्य तत्रेष्टापूर्तकर्मफलं भुक्त्धा पुनरावर्तते",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "र धूमरात्रिकृष्णपक्षदक्षिणायनदेवता इहोक्ताः",
          "school": "advaita-bhakti",
