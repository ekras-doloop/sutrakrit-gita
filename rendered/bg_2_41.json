      "senses_attested_in_panel": [
        {
          "sense": "नन्तः अपारः अनुपरतः संसारो नित्यप्रततो विस्तीर्णो भवति प्रमाणजनितविवेकबुद्धिनिमित्तवशाच्च उपरतास्वनन्तभेदबुद्धिषु संसारो",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "नुष्ठेये कर्मणि बुद्धिः व्यवसायात्मिका बुद्धिः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "परं मतमाश्रितास्तत्प्रतिषेधेनान्यदाहुः",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "फलार्थं भगवदर्थं वा कर्म किञ्चित्कर्त्तव्यमिति निश्चयरूपा बुद्धिरेकविषयत्वादेका",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "व्यवसायिनां तु बहुर्मुखानां कामिनां कामानामानन्त्यादनन्ताः तत्रापि कर्मगुणफलादिभेदाद्बहुशाखाश्च बुद्धयो भवन्ति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "न्ये तु परमेश्वराराधनेनैव संसारं तरिष्यामीति निश्चयात्मिका एकनिष्ठैव बुद्धिरिह कर्मयोगे भवतीत्यर्थमाहुः",
          "school": "advaita-bhakti",
          "weight": 1.0,
