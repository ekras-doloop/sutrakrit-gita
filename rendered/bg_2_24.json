      "senses_attested_in_panel": [
        {
          "sense": "गतः। सर्वगतत्वात् स्थाणुः इव स्थिर इत्येतत्। स्थिरत्वात् अचलः अयम् आत्मा। अतः सनातनः चिरंतनः न कारणात्कुतश्चित् निष्पन्न",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "गतत्वाद् आत्मनः सर्वतत्त्वव्यापकस्वभावतया सर्वेभ्यः तत्त्वेभ्यः सूक्ष्मत्वात् अस्य तैः व्याप्त्यनर्हत्वाद् व्याप्यकर्तव्",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "शास्त्रेषु महाभारतमुत्तमम्",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "गत इति व्यापकत्वम्",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "त्रगतः स्थाणुः स्थिरस्वभावः रूपान्तरापत्तिशून्यः अचलः पूर्वरूपापरित्यागी सनातनोऽनादिः",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "गतत्वे ह्यनित्यत्वं स्यात्यावद्विकारं तु विभागः इति न्यायात्पराभ्युपगतपरमाण्वादीनामनभ्युपगमात्",
          "school": "advaita-bhakti",
          "weight": 1.0,
