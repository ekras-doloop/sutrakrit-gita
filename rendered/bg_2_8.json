      "senses_attested_in_panel": [
        {
          "sense": "िःश्रेयसमेवेच्छसि तत्राह नहीति",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "िवृत्तव्यापारान् भवतो धार्तराष्ट्राः प्रसह्य हन्युः इति चेत् अस्तु तद्वधलब्धविजयात् अधर्म्याद् अस्माकं धर्माधर्मौ अजानद्",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "चैतदिति प्रश्नस्त्रिभिः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "हीति। इन्द्रियाणामुच्छोषणमतिशोषणकरं मदीयं शोकं यत्कर्मापनुद्यादपनयेत्तदहं न प्रपश्यामि। यद्यपि भूमौ निष्कण्टकं समृद्धं र",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "नु स्वयमेव त्वं श्रेयो विचारय श्रुतसंपन्नोऽसि किं परशिष्यत्वेनेत्यत आह यच्छ्रेयः प्राप्तं सत् कर्तृ मम शोकमपनुद्यादपनुदे",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
