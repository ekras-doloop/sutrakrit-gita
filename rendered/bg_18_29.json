      "senses_attested_in_panel": [
        {
          "sense": "ैव भेदं गुणतः सत्त्वादिगुणतः त्रिविधं श्रृणु इति सूत्रोपन्यासः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "यरूपं ज्ञानम्? धृतिः आरब्धायाः क्रियायाः विघ्नोपनिपतिं",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ज्ञेयस्यापि त्रैविध्यं बुद्धेः त्रैविध्येन करणस्याप्युक्तमिति निश्चयरूपाया बुद्धेर्धृतेश्च गुणतस्त्रैविध्यं प्रतिजानन्न",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ापि त्रैविध्यं प्रतिजानीते -- बुद्धिरिति",
