{
  "verse_id": "3.18",
  "mūla": {
    "devanāgarī": "नैव तस्य कृतेनार्थो नाकृतेनेह कश्चन | न चास्य सर्व-भूतेषु कश्चिद् अर्थ-व्यपाश्रयः",
    "iast": "naiva tasya kṛtenārtho nākṛteneha kaścana | na cāsya sarva-bhūteṣu kaścid artha-vyapāśrayaḥ",
    "chapter_position": "Chapter 3 (Karma-Yoga (The Yoga of Action)), verse 18",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "na",
      "lemma": "na",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "ैव तस्य परमात्मरतेः कृतेन कर्मणा अर्थः प्रयोजनमस्ति। अस्तु तर्हि अकृतेन अकरणेन प्रत्यवायाख्यः अनर्थः न अकृतेन इह लोके कश",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ाय कृतेन तत्साधनेन न अर्थः न किञ्चित् प्रयोजनम् अकृतेन आत्मदर्शनसाधनेन न कश्चिद् अनर्थः असाधनायत्तात्मदर्शनत्वात्",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ास्ति। न च सन्ध्याद्यकृतौ कश्चिद्दोषोऽस्ति। न चैतदपहाय सर्वभूतेषु कश्चित्प्रयोजनाश्रयः। अर्थो येन दर्शनादिना भवति सोऽर्थ",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "ैवेति। तस्य कृतेन निषिद्धेन चार्थः फलं सुखदुःखादि नास्ति। किञ्चार्थार्थमाश्रयः कश्चिन्नास्ति।",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ैव तस्येति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "न्वात्मविदोऽप्यभ्युदयार्थं निःश्रेयसार्थं प्रत्यवायपरिहारार्थं वा कर्म स्यादित्यतआह तस्यात्मरतेः कृतेन कर्मणाभ्युदयलक्षण",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
