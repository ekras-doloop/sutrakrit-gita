    {
      "surface_form": "paritrāṇāya",
      "lemma": "paritrāṇa",
      "grammar": "dative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "परिरक्षणाय साधूनां सन्मार्गस्थानाम् विनाशाय",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "तद्विपरीतानां विनाशाय",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "साधूनां इति साधुपरित्राणादिकं भगवदवतारस्य प्रयोजनमुक्तम् तत्र किं जन्मनैव परित्राणादिकं कार्यमिति नियमः इत्यपेक्षायामाह",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "ेति। साधूनां धर्मवतां परित्राणाय तत्प्रतिपक्षाणां दुष्कृतां दुष्टं कर्म कुर्वतां विनाशाय च युगेयुगे सम्भवामि। न चात्रावत",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ेति। साधूनां स्वधर्मवर्तिनां रक्षणाय। दुष्टं कर्म कुर्वन्तीति दुष्कृतस्तेषां वधाय च। एवं धर्मस्य संस्थापनार्थाय साधुरक्ष",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "परितः सर्वतो रक्षणाय तथा अधर्मवृद्ध्या वर्धमानानां दुष्कृतां पापकारिणां वेदमार्गविरोधिनां विनाशाय",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "sādhūnām",
      "lemma": "sādhu",
      "grammar": "Vibhakti.Sasthi plural neuter noun",
      "senses_attested_in_panel": [],
      "theme_lists": []
    },
    {
      "surface_form": "vināśāya",
      "lemma": "vinaś",
      "grammar": "dative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "च दुष्कृतां पापकारिणाम् किञ्च धर्मसंस्थापनार्थाय धर्मस्य सम्यक् स्थापनं तदर्थं संभवामि युगे युगे प्रतियुगम्।।तत्",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "च क्षीणस्य वैदिकधर्मस्य मदाराधनरूपस्य आराध्यस्वरूपप्रदर्शनेन तस्य स्थापनाय च देवमनुष्यादिरूपेण युगे युगे संभवामि। कृतत्",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "च युगेयुगे सम्भवामि। न चात्रावतारकालनियम इत्येतदर्थं यदा यदा युगेयुगे इत्युक्तम् नचैवं दुष्टनिग्रहं कुर्वतोऽपि वैषम्यं",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "च तदुभयं कथं स्यादिति तदाह। धर्मसंस्थापनार्थाय धर्मस्य सम्यगधर्मनिवारणेन स्थापनं वेदमार्गपरिरक्षणं धर्मसंस्थापनं तदर्थं",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
