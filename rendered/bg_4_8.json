{
  "verse_id": "4.8",
  "mūla": {
    "devanāgarī": "किम्-अर्थम् ? परित्राणाय साधूनां विनाशाय च दुष्कृताम् | धर्म-संस्थापनार्थाय संभवामि युगे युगे",
    "iast": "kim-artham ? paritrāṇāya sādhūnāṃ vināśāya ca duṣkṛtām | dharma-saṃsthāpanārthāya saṃbhavāmi yuge yuge",
    "chapter_position": "Chapter 4 (Jñāna-Karma-Sannyāsa-Yoga (The Yoga of Renunciation of Action in Knowledge)), verse 8",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
