            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "मामिकां मच्छरीरभूतां प्रकृतिं तमःशब्दवाच्यां नामरूपविभागानर्हां कल्पक्षये चतुर्मुखावसानसमये मत्संकल्पाद् यान्ति",
          "school": "viśiṣṭādvaita",
