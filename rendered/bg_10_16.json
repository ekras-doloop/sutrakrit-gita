      "senses_attested_in_panel": [
        {
          "sense": "। दिव्याः हि आत्मविभूतयः। आत्मनो विभूतयो याः ताः वक्तुम् अर्हसि। याभिः विभूतिभिः आत्मनो माहात्म्यविस्तरैः इमान् लोकान् त",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "इति निर्देशाच्च आनन्त्यमिह विवक्षितम्",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति। या दिव्यास्तवासाधारण्यो विभूतयः ता अशेषेण वद। याभिः स्वांशभवनरूपैर्नियमनविशेषैर्गुणभूतैस्तदात्मभूतैश्चेमाँल्लोकांस्",
          "school": "śuddhādvaita",
