            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "ye",
      "lemma": "yā",
      "grammar": "locative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "ष्यते च पठिष्यति यः इमं धर्म्यं धर्मादनपेतं संवादरूपं ग्रन्थं आवयोः? तेन इदं कृतं स्यात्। ज्ञानयज्ञेन -- विधिजपोपांशुमान",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ष्यते? तेन ज्ञानयज्ञेन अहम् इष्टः स्याम् इति मे मतिः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "तुः फलं निर्दिशति -- अध्येष्यत इति",
          "school": "śuddhādvaita",
          "weight": 1.0,
