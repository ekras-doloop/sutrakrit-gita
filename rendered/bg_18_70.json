      "senses_attested_in_panel": [
        {
          "sense": "नां यज्ञानां मध्ये ज्ञानयज्ञस्यश्रेयान्द्रव्यमयाद्यज्ञाज्ज्ञानयज्ञः इति विशिष्टत्वाभिधानात्तेनाहमिष्टः स्यामित्यध्ययनस्य",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "वेक्षणेन स्वसंवादाध्ययनभावित्वोक्तिः अपितु भूतावेक्षणेन",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "नपूर्वकं पठतस्तु साक्षादेव मोक्ष इति किमु वक्तव्यमिति फलविधिरेवायं नार्थवादः",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
