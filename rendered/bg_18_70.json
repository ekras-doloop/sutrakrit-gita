      "senses_attested_in_panel": [
        {
          "sense": "अस्य फलं भवतीति -- तेन अध्ययनेन अहम् इष्टः पूजितः स्यां भवेयम् इति मे मम मतिः निश्चयः",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। अतएव अजामिलक्षत्रबन्धुप्रमुखानां कथंचिन्नामोच्चारणमात्रेण प्रसन्नोऽस्मि? तथैवास्यापि प्रसन्नो भवेयमित्यर्थः।",
