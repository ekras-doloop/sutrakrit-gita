          ]
        },
        {
          "sense": "प्रपञ्चप्रकृतिं भित्त्वा यस्तिष्ठति एवंभूतं पुरुषमन्तकाले भक्तियुक्तो निश्चलेन विक्षेपरहितेन मनसा योऽनुस्मरेत्",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "्मरणे प्रयत्नातिरेकोऽभ्यर्थते तदाह -- प्रयाणकालेऽन्तकाले अचलेन एकाग्रेण मनसा तं पुरुषं योऽनुस्मरेदित्यनुवर्तते",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
