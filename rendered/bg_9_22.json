      "grammar": "locative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "जनाः संन्यासिनः पर्युपासते? तेषां परमार्थदर्शिनां नित्याभियुक्तानां सतताभियोगिनां योगक्षेमं योगः अप्राप्तस्य प्रापणं क्",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "महात्मानः जनाः पर्युपासते सर्वकल्याणगुणान्वितं सर्वविभूतियुक्तं मां परित उपासते अन्यूनम् उपासते तेषां नित्याभियुक्तानां",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "चिन्तयन्तीह तमेव धीरा अनन्यास्ते देवमेवाविशन्ति इति",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "षां जीवानां दैवानां मर्यादायामङ्गीकारस्तेषां साधनक्रमेणैव भगवत्प्राप्तिः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "षां तथाभूता ये जना मां चिन्तयन्तः सेवन्ते? तेषां नित्याभियुक्तानां सर्वदा मदेकनिष्ठानां योगं धनादिलाभं क्षेमं",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "षां तेऽनन्याः सर्वाद्वैतदर्शिनः सर्वभोगनिःस्पृहा अहमेव भगवान्वासुदेवः सर्वात्मा न मद्व्यतिरिक्तं किंचिदस्तीति ज्ञात्वा त",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
