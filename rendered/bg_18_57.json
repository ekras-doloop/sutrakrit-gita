      "grammar": "instrumental singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "श्रयः अनन्यशरणत्वं मच्चित्तः मय्येव चित्तं यस्य तव सः त्वं मच्चित्तः सततं सर्वदा भव",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "त्मनो मदीयत्वमन्नियाम्यत्वबुद्ध्या उक्तं हिमयि सर्वाणि कर्माणि संन्यस्याध्यात्मचेतसा",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        }
      ],
      "theme_lists": []
    },
    {
