      "grammar": "vocative plural neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "दृष्टादृष्टार्थानि मयि ईश्वरे संन्यस्य",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "सकर्तृकाणि साराध्यानि मयि संन्यस्य मत्परः अहम्",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "चेतसा मयि संन्यस्य समर्प्य मत्परः अहमेव परः प्राप्यः पुरुषार्थो यस्य सः व्यवसायात्मिकया बुद्ध्या योगमाश्रित्य सततं कर्म",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "दृष्टादृष्टार्थानि मयीश्वरे संन्यस्ययत्करोषि यदश्नासि इत्युक्तन्यायेन समर्प्य मत्परोऽहं भगवान्वासुदेव",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
