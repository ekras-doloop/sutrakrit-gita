      "senses_attested_in_panel": [
        {
          "sense": "। भूतानि भावयतीति भूतभावनः? हे भूतभावन। भूतेश भूतानाम् ईशितः। हे देवदेव जगत्पते ।।",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "आत्मना आत्मानं त्वं स्वयम्",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "। पुरुषोत्तमत्वे हेतुगर्भाणि संबोधनानि। हे भूतभावन भूतोत्पादक भूतानामीश नियन्तः? देवानामादित्यादीनां देव प्रकाशक? जगत्पत",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "? त्वदपेक्षया सर्वेऽपि पुरुषा अपकृष्टा एव",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
