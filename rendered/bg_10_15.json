      "grammar": "2nd person singular present indicative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "जानासि त्वं निरतिशयज्ञानैश्वर्यबलादिशक्तिमन्तम् ईश्वरं पुरुषोत्तम",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। भूतभावन सर्वेषां भूतानाम् उत्पादयितः? भूतेश सर्वेषां भूतानां नियन्तः? देवदेव दैवतानाम् अपि परमदैवत? यथा मनुष्यमृगपक्षि",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति तदप्यात्मना? न साधनान्तरेण",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "जानासि नान्यः तदप्यात्मना स्वेनैव वेत्थ न साधनान्तरेण",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "जानासि नान्यः कश्चित्",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
