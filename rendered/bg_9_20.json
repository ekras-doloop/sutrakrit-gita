      "surface_form": "prārthayante",
      "lemma": "praarthi",
      "grammar": "3rd person plural present indicative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "। ते च पुण्यं पुण्यफलम् आसाद्य संप्राप्य सुरेन्द्रलोकं शतक्रतोः स्थानम् अश्नन्ति भुञ्जते दिव्यान् दिवि भवान् अप्राकृतान्",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। ते पुण्यं दुःखासंभिन्नं सुरेन्द्रलोकं प्राप्य तत्र दिव्यान् देवभोगान् अश्नन्ति।",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "।।स्वर्गतिमित्युपलक्षणं कर्मानुगुणलोकानाम्। तथाहि निबन्धे -- सात्त्विकः सात्त्विकं कर्म यथा श्रुतिपरः कृती। स्वर्गलोकस्त",
          "school": "śuddhādvaita",
          "weight": 0.8,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ते पुण्यफलरूपं सुरेन्द्रस्य लोकं स्वर्गमासाद्य प्राप्य दिवि स्वर्गे दिव्यानुत्तमान्देवानां भोगानश्नन्ति भुञ्जते",
          "school": "bhakti",
          "weight": 0.8,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "नतु सत्त्वशुद्धिज्ञानोत्पत्त्यादि",
          "school": "advaita-bhakti",
          "weight": 0.8,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
