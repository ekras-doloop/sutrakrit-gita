{
  "verse_id": "9.20",
  "mūla": {
    "devanāgarī": "त्रैविद्या मां सोमपाः पूत-पापा यज्ञैर् इष्ट्वा स्वर्-गतिं प्रार्थयन्ते | ते पुण्यम् आसाद्य सुरेन्द्र-लोकम् अश्नन्ति दिव्यान् दिवि देव-भोगान्",
    "iast": "traividyā māṃ somapāḥ pūta-pāpā yajñair iṣṭvā svar-gatiṃ prārthayante | te puṇyam āsādya surendra-lokam aśnanti divyān divi deva-bhogān",
    "chapter_position": "Chapter 9 (Rāja-Vidyā-Rāja-Guhya-Yoga (The Yoga of Royal Knowledge and Royal Mystery)), verse 20",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
