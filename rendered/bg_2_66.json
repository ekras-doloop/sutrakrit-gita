      "senses_attested_in_panel": [
        {
          "sense": "ास्ति न विद्यते न भवतीत्यर्थः बुद्धिः आत्मस्वरूपविषया अयुक्तस्य असमाहितान्तःकरणस्य",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "्यस्तमनोरहितस्य खयत्नेन इन्द्रियदमने प्रवृत्तस्य कदाचिद्",
