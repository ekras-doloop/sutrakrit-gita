      "senses_attested_in_panel": [
        {
          "sense": "ईश्वरेण सर्वम् इदं ततं जगत् व्याप्तम् स्वकर्मणा पूर्वोक्तेन प्रतिवर्णं तम् ईश्वरम् अभ्यर्च्य पूजयित्वा आराध्य केवलं ज्ञ",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "च सर्वम् इदं ततं स्वकर्मणां तं माम् इन्द्राद्यन्तरात्मतयावस्थितम् अभ्यर्च्य मत्प्रसादात् मत्प्राप्तिरूपां सिद्धिं विन्द",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ाक्षरेण भगवत्स्वरूपेणेदं ततं तमेवाभ्यर्च्य? न तु देवान्तरं? तदा सिद्धिं मुक्तिं प्राप्नोति स्वकर्मणेति द्रढयति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "च कारणात्मना सर्वमिदं विश्वं ततं व्याप्तं तमीश्वरं स्वकर्मणाऽभ्यर्च्य पूजयित्वा सिद्धिं लभते मनुष्यः।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
