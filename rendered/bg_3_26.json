      "senses_attested_in_panel": [
        {
          "sense": "िश्चयरूपाया बुद्धेः भेदनं चालनं बुद्धिभेदः तं न जनयेत् न उत्पादयेत् अज्ञानाम् अविवेकिनां कर्मसङ्गिनां कर्मणि आसक्तानां आ",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ाम् आत्मन्यकृत्स्नवित्तया ज्ञानयोगोपादानाशक्तानां मुमुक्षूणां कर्मसङ्गिनाम् अनादिकर्मवासनया कर्मणि",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "न्वज्ञेषु तु सक्ततया कर्मनिष्ठेषु कृपया साङ्ख्यप्रकारभेद उपदेष्टुं युक्तो विदुषा नहिनहीत्याह न बुद्धिभेदमिति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "नु कृपया तत्त्वज्ञानमेवोपदेष्टुं युक्तं नेत्याह नेति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "नु कर्मानुष्ठानेनैव लोकसंग्रहः कर्तव्यो नतु तत्त्वज्ञानोपदेशेनेति को",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
