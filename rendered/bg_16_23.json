          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "मादश्रेयोनाचरणस्य श्रेयआचरणस्य न शास्त्रमेव निमित्तं तयोः शास्त्रैकगम्यत्वात्तस्मात् --",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
