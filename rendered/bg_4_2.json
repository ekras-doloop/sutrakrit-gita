            "shankara"
          ]
        },
        {
          "sense": "कथनस्य तात्पर्यमाह योऽयमित्यादिना मन्तव्यमित्यन्तेन",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "कथनं प्रकृतानुपयुक्तमित्यतस्तत्तात्पर्यमाह पूर्वे ति",
