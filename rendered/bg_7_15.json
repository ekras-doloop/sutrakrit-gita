{
  "verse_id": "7.15",
  "mūla": {
    "devanāgarī": "न मां दुष्कृतिनो मूढाः प्रपद्यन्ते नराधमाः | माययापहृत-ज्ञाना आसुरं भावम् आश्रिताः",
    "iast": "na māṃ duṣkṛtino mūḍhāḥ prapadyante narādhamāḥ | māyayāpahṛta-jñānā āsuraṃ bhāvam āśritāḥ",
    "chapter_position": "Chapter 7 (Jñāna-Vijñāna-Yoga (The Yoga of Knowledge and Realization)), verse 15",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "na",
      "lemma": "na",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "मां परमेश्वरं नारायणं दुष्कृतिनः पापकारिणः मूढाः प्रपद्यन्ते नराधमाः नराणां मध्ये अधमाः निकृष्टाः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ः पापकर्माणो दुष्कृततारतम्यात् चतुर्विधा न प्रपद्यन्ते मूढा नराधमाः मायया अपहृतज्ञाना आसुरं भावम् आश्रिताः इति",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ात्याययन्नित्यत आह न मामिति",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "प्रपद्यन्ते मायातारकत्वादित्याह न मां दुष्कृतिन इति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "भजन्ति तत्राह न मामिति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "िखिलानर्थमूलमायोन्मूलनाय भगवन्तं भवन्तमेव सर्वे न प्रतिपद्यन्ते चिरसंचितदुरितप्रतिबन्धादित्याह भगवान् दुष्कृतिनो दुष्कृत",
