      "grammar": "locative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "? नैष्कृतिकः परविभेदनपरः? अलसः अप्रवृत्तिशीलः कर्तव्येष्वपि? विषादी विषादवान् सर्वदा अवसन्नस्वभावः? दीर्घसूत्री",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "यकर्मायोग्यः विकर्मस्थः? प्राकृतः अनधिगतविद्यः? स्तब्धः अनारम्भशीलः? शठः अभिचारादिकर्मरुचिः? नैष्कृतिकः वञ्चनपरः? अलसः आ",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "।परेण यः कृतो दोषो दीर्घकालकृतोऽपि वा। यस्तस्य सूचको दोषाद्दीर्घसूत्री स उच्यते इत्यभिधानात्।",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "madhva"
          ]
        },
        {
          "sense": "यकर्माधिकारी सन् योऽयुक्तः विकर्मस्थः अनधिगतविद्यः स्तब्धः आरम्भशिथिलः शठः अभिचारादिकर्मरुचिः वञ्चकः कर्मस्वलसो दुःखी दी",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "? नैष्कृतिकः परावमानी? अलसोऽनुद्यमशीलः? विषादी शोकशीलः? यदद्य वा श्वो या कार्यं तन्मासेनापि न संपादयति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "निरन्तरशङ्कासहस्रकवलितान्तःकरणत्वेनातिमन्थरप्रवृत्तिर्यदद्यकर्तव्यं तन्मासेनापि करोति नवेत्येवंशीलश्च? कर्ता तामस उच्यत",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
