      "senses_attested_in_panel": [
        {
          "sense": "अर्जुन निष्कामो भव इत्यर्थः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ेयुः। अतः त्रैगुण्यविषया वेदाः त्वं तु निस्त्रैगुण्यो भव इदानीं सत्त्वप्रचुरः त्वं तदेव वर्धय नान्योन्यसंकीर्णगुणत्रयप्र",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "इत्यनेन वेदपरित्यागो विधीयते इत्यन्यथाप्रतीतिनिरासाय व्याचष्टे वेदानामि ति",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "। त्रिगुणमाश्रितस्त्रैगुण्यस्तद्भिन्नो निस्त्रैगुण्यः। निस्त्रिगुणं मामाश्रितो भवेति गूढाभिप्रायः। तल्लिङ्गमाह निर्द्वन्",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ति तर्हि किमिति वेदैस्तत्साधनतया कर्माणि विधीयन्ते तत्राह त्रैगुण्यविषया इति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ति तत्तत्कामनाविरहात्",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
