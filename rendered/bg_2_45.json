          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ः तमःप्रचुराणां रजःप्रचुराणां सत्त्वप्रचुराणां",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "नां परोक्षार्थत्वात्ित्रगुणसम्बन्धिस्वर्गादिप्रतीतितोऽर्थ इव भाति",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "इति। यत एवं कामात्मनां त्रैगुण्याधिकारिणां त्रैगुण्यफलविषया वेदास्त्रिकाण्डविषया अपि अतस्त्वं वेदादिमूलानिस्त्रिगुणतत्त",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ः। त्वं तु निस्त्रैगुण्यो निष्कामो भव। तत्रोपायमाह। निर्द्वन्द्वः सुखदुःखशीतोष्णादियुगुलानि द्वन्द्वानि तद्रहितो भव। तान",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ः कर्मकाण्डात्मकाः यो",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
