      "senses_attested_in_panel": [
        {
          "sense": "? अर्दतेः गतिकर्मणः रूपम्? असुराणां देवप्रतिपक्षभूतानां जनानां नरकादिगमयितृत्वात् जनार्दनः अभ्युदयनिःश्रेयसपुरुषार्थप्रय",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ः। विस्तरबुभुत्साहेतुज्ञापनार्थं योगशब्दविवक्षितव्यक्त्यर्थं च भूयश्शब्दफलितमाह -- अहं सर्वस्येति। अमृतशब्दोऽत्रातृप्तिस",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "ः। तथा च बाभ्रव्यशाखायाम् -- स भूतः स जनार्दनः इति। स ह्यासीत्स नासीत्सोऽर्दयत् इति।",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "? अतो ममापि याञ्चा त्वय्युचितैव",
          "school": "advaita-bhakti",
          "weight": 1.0,
