      "senses_attested_in_panel": [
        {
          "sense": "। किंविशिष्टया धृतिगृहीतया धृत्या धैर्येण गृहीतया धृतिगृहीतया धैर्येण युक्तया इत्यर्थः। आत्मसंस्थम् आत्मनि संस्थितम् आत्",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "सर्वस्माद् आत्मव्यतिरिक्ताद् उपरम्य आत्मसंस्थं मनः कृत्वा न किञ्चिद्",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "इति बुद्धेरपीन्द्रियग्रामनियमने कारणत्वस्य वक्ष्यमाणत्वात् कथमेतदित्यत आह बुद्धेरि ति",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "त्मसंस्थमात्मन्येव सम्यक् स्थितं निश्चलं मनः कृत्वोपरमेत्",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "सूक्ष्मया सूक्ष्मदर्शिभिः इति पूर्वमभिधाय सूक्ष्मत्वसिद्धये निरोधसमाधेरभिधानात्",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
