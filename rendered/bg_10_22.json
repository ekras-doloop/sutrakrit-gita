{
  "verse_id": "10.22",
  "mūla": {
    "devanāgarī": "वेदानां साम-वेदो ऽस्मि देवानाम् अस्मि वासवः | इन्द्रियाणां मनश् चास्मि भूतानाम् अस्मि चेतना",
    "iast": "vedānāṃ sāma-vedo 'smi devānām asmi vāsavaḥ | indriyāṇāṃ manaś cāsmi bhūtānām asmi cetanā",
    "chapter_position": "Chapter 10 (Vibhūti-Yoga (The Yoga of Divine Manifestations)), verse 22",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
