      "grammar": "1st person singular present indicative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "। देवानां रुद्रादित्यादीनां वासवः इन्द्रः अस्मि। इन्द्रियाणाम् एकादशानां चक्षुरादीनां मनश्च अस्मि संकल्पविकल्पात्मकं मनश",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। एकादशानाम् इन्द्रियाणां यद् उत्कृष्टं मन इन्द्रियं तद् अहम् अस्मि। इयम् अपि न निर्धारणे -- भूतानां,चेतनावतां या चेतना",
