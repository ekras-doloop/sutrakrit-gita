      "senses_attested_in_panel": [
        {
          "sense": "इति सामान्येन निर्दिष्टं पूर्वापरग्रन्थस्थैः पदैर्विवृणोति -- इद ते परमं गुह्यं शास्त्रं मयाऽऽख्यातमिति",
          "school": "viśiṣṭādvaita",
