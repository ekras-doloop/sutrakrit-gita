      "grammar": "nominative dual feminine noun",
      "senses_attested_in_panel": [
        {
          "sense": "तव हिताय मया उक्तं संसारविच्छित्तये अतपस्काय तपोरहिताय न वाच्यम् इति व्यवहितेन संबध्यते",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "परमं गुह्यं शास्त्रं मया आख्यातम् अतपस्काय अतप्ततपसे त्वया न वाच्यं त्वयि वक्तरि मयि",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "त्वयाऽतपस्काय न वाच्यम्",
