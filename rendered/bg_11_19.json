      "grammar": "1st person singular present indicative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "त्वां दीप्तहुताशवक्त्रं दीप्तश्च असौ हुताशश्च वक्त्रं यस्य तव सः त्वं दीप्तहुताशवक्त्रः तं त्वां दीप्तहुताशवक्त्रम्? स्",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। एवंभूतं सर्वस्य स्रष्टारम्? सर्वस्य आधारभूतं सर्वस्य प्रशासितारम्? सर्वस्य संहर्तारम्? ज्ञानाद्यपरिमितगुणसागरम्? आदिमध",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। तथा दीप्तो हुताशोऽग्निर्वक्त्रेषु यस्य तम् स्वतेजसा इदं विश्वं तपन्तं संतापयन्तं पश्यामि।",
          "school": "bhakti",
          "weight": 0.8,
          "witnesses": [
            "sridhara"
          ]
        }
      ],
