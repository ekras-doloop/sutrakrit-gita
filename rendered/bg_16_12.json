          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "एव पाशास्तेषां शतानि तैर्बद्धा इतस्तत आकृष्यमाणाः? कामक्रोधौ परमयनमाश्रयो येषां ते? कामभोगार्थमन्यायेन चौर्यादिनाऽर्थान",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "स्ता एव पाशा इव बन्धनहेतुत्वात्पाशास्तेषां शतैः समूहैर्बद्धा इव श्रेयसः प्रच्याव्येतस्तत आकृष्य नीयमानाः कामक्रोधौ परमयन",
          "school": "advaita-bhakti",
