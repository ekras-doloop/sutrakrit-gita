          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। तत्रानात्मनि प्रकृतितत्कार्ये स्वात्माभिमानरूपो मोहः परमपुरुषस्वरूपतया तदात्मकस्य सर्वस्य चिदचिद्वस्तुनः अतदात्माभिमान",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "। अतः स्थितोऽस्मि युद्धायोपस्थितोऽस्मि। गतो धर्मविषयः संदेहो यस्य सोऽहं तवाज्ञां करिष्य इति।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
