      "senses_attested_in_panel": [
        {
          "sense": "भावाः।अतुविष्टिः परितापश्च क्रोधो मोहस्तथा क्षमा इत्यादयो राजसाः।अविक्तस्तथा मोहः प्रमादः स्वप्नतन्द्रिता इत्यादयस्तामस",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "भावाः शमदमादयः राजसाश्च द्वेषदर्पादयः तामसाश्च शोकमोहादयः प्राणिनां स्वकर्मवशाज्जायन्ते तान्सर्वान्मत्त",
