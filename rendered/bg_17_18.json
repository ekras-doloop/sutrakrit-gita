      "senses_attested_in_panel": [
        {
          "sense": "चैव यत् क्रियते तपः तत् इह प्रोक्तं कथितं राजसं चलं कादाचित्कफलत्वेन अध्रुवम् ।।",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "हेतुना यत् तपः क्रियते तद् इह राजसं प्रोक्तम् स्वर्गादिफलसाधनत्वेनास्थिरत्वात् चलम् अध्रुवम् चलत्वं पातभयेन चलनहेतुत्वम",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "च यत्तपः क्रियते अतएव चलं अनियतं अध्रुवं च क्षणिकं। यदेवंभूतं तपस्तदिह राजसं प्रोक्तम्।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ैव च केवलं धर्मध्वजित्वेनैव च न त्वास्तिक्यबुद्ध्या यत्तपः क्रिये तद्राजसं प्रोक्तं शिष्टैः इहास्मिन्नेव लोके फलदं न पार",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
