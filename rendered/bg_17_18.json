{
  "verse_id": "17.18",
  "mūla": {
    "devanāgarī": "सत्कार-मान-पूजार्थं तपो दम्भेन चैव यत् | क्रियते तद् इह प्रोक्तं राजसं चलम् अध्रुवम्",
