      "surface_form": "satkāra",
      "lemma": "satkāra",
      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "ः साधुकारः साधुः अयं तपस्वी ब्राह्मणः इत्येवमर्थम्? मानो माननं प्रत्युत्थानाभिवादनादिः तदर्थम्? पूजा पादप्रक्षालनार्चनाश",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ः? वाचा प्रशंसा मानम्? शारीरो नमस्कारादिः पूजा",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "इति। सत्कारः साधुकारः साधुरयमिति तापस इत्यादि वाक्पूजा? मानः प्रत्युत्थानाभिवादनादिः दैहिकीपूजाऽर्थलाभादिः? एतदर्थं दम्",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ेति। सत्कारः साधुरयं तपस्वी ब्राह्मण इत्येवमविवेकिभिः क्रियमाणा स्तुतिः मानः प्रत्युत्थानाभिवादनादिः? पूजा पादप्रक्षालना",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
