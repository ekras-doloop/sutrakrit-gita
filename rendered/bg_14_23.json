          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "य चैकार्थ्यं दर्शयन्नविचाल्यताहेतुमाहगुणाः स्वेषु कार्येष्विति",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "तूष्णीमवतिष्ठति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "येवैतत्सर्वभासकस्य न केनापि भास्यधर्मेण संबन्धः? स्वप्नवन्मायामात्रश्चायं भास्यप्रपञ्चो जडः? स्वयंज्योतिः स्वभावस्त्वहं",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "na",
      "lemma": "na",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "वत् यथा उदासीनः न कस्यचित् पक्षं भजते? तथा अयं गुणातीतत्वोपायमार्गेऽवस्थितः आसीनः आत्मवित् गुणैः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "वद् आसीनः गुणव्यतिरिक्तात्मावलोकनतृप्त्या अन्यत्र उदासीनवद् आसीनः गुणैः द्वेषाकाङ्क्षाद्वारेण यो न विचाल्यते? गुणाः स्वे",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "वदिति। गुणातिरिक्तात्मावलोकनतृप्तत्वात् अन्यत्रानात्मवस्तुनि उदासीनवदासीनः द्वेषाकाङ्क्षाद्वारेण गुणैश्च यो न विचाल्यते?",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "स्योत्तरमाह -- उदासीनवदिति त्रिभिः",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "स्य प्रतिवचनमाह त्रिभिः -- यथोदासीनो द्वयोर्विवदमानयोः कस्यचित्पक्षमभजमानो न रज्यति न वा द्वेष्टि तथायमात्मविद्रागद्वेषश",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
        "उदासीन"
      ]
    },
    {
      "surface_form": "vica",
      "lemma": "vici",
      "grammar": "instrumental singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "ाल्यते विवेकदर्शनावस्थातः",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "ाल्यते? गुणाः स्वेषु कार्येषु प्रकाशादिषु वर्तन्ते इति अनुसंधाय",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ाल्यते? किन्तु स्वकार्येषु प्रकाशादिषु गुणा वर्त्तन्त इति तिष्ठति न गुणानुगुणं स्वात्मना चेष्टते",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ाल्यते स्वरूपान्न प्रच्याव्यते अपितु गुणा",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ाल्यते न प्रच्याव्यते स्वरूपावस्थानात् किंतु गुणा एवैते देहेन्द्रियविषायाकारपरिणताः परस्परस्मिन्वर्तन्ते ममत्वादित्यस्ये",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
