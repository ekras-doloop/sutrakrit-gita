      "senses_attested_in_panel": [
        {
          "sense": "द्रष्टुम् अनेनैव प्राकृतेन स्वचक्षुषा स्वकीयेन चक्षुषा",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। तव दिव्यम् अप्राकृतं मद्दर्शनसाधनं, चक्षुः ददामि। पश्य मे योगम् ऐश्वरं मदसाधारणं योगं पश्य? मम अनन्तज्ञानादियोगम् अनन्",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "? अतोऽहं दिव्यमप्राकृतज्ञानात्मकदर्शनसाधनं चक्षुर्ददामि? तेन ममैश्वरं योगं मत्स्वरूपगतं सर्व विभिन्नधर्माश्रयणं पश्य साक",
          "school": "śuddhādvaita",
          "weight": 0.8,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "शक्तो न भविष्यसि",
          "school": "bhakti",
          "weight": 0.8,
          "witnesses": [
            "sridhara"
          ]
        },
        {
