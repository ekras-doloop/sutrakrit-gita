          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "सक्ता अभिनिविष्टाः सन्तोऽज्ञाः यथा कर्म कुर्वन्ति तथैव असक्तः सन् विद्वानपि कुर्यात् लोकसंग्रहं कर्तुमिच्छुः",
          "school": "bhakti",
