          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "्यच्च। यथा समुद्रो न कं प्रतियाति किन्तु तं प्रत्येवापः सर्वा यान्ति तथा कामाः सर्वे तमेव विशन्ति तत आप्तकामः स शानतिमाप",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "नु विषयेषु दृष्ट्यभावे कथमसौ तान्भुङ्क्त इत्यपेक्षायामाह आपूर्यमाणमिति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "्तिरप्यर्थसिद्धेति सदृष्टान्तमाह सर्वाभिर्नदीभिरापूर्यमाणं सन्तं वृष्ट्यादिप्रभवा",
          "school": "advaita-bhakti",
          "weight": 1.0,
