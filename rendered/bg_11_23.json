{
  "verse_id": "11.23",
  "mūla": {
    "devanāgarī": "रूपं महत् ते बहु-वक्त्र-नेत्रं महा-बाहो बहु-बाहूरु-पादम् | बहूदरं बहु-दंष्ट्रा-करालं दृष्ट्वा लोकाः प्रव्यथितास् तथाहम्",
    "iast": "rūpaṃ mahat te bahu-vaktra-netraṃ mahā-bāho bahu-bāhūru-pādam | bahūdaraṃ bahu-daṃṣṭrā-karālaṃ dṛṣṭvā lokāḥ pravyathitās tathāham",
    "chapter_position": "Chapter 11 (Viśvarūpa-Darśana-Yoga (The Yoga of the Vision of the Universal Form)), verse 23",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "rū",
      "lemma": "ru",
      "grammar": "nominative dual masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "पं महत् अतिप्रमाणं ते तव बहुवक्त्रनेत्रं बहूनि वक्त्राणि मुखानि नेत्राणि चक्षूंषि",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "पं दृष्ट्वा अतीव व्यथिता भवामः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "पमिति। हे महाबाहो? महदत्यूर्जितं तव रूपं दृष्ट्वा लोकाः सर्वे प्रव्यथिता अतिभीताः? तथाहं प्रव्यथितोऽस्मि। कीदृशं रूपं दृ",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "पमिति। हे महाबाहो? ते तव रूपं दृष्ट्वा लोकाः सर्वेऽपि प्राणिनः प्रव्यथितास्तथाऽहं प्रव्यथितो भयेन। कीदृशं ते रूपम्। महत्",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
