{
  "verse_id": "3.28",
  "mūla": {
    "devanāgarī": "तत्त्ववित् तु महाबाहो गुण-कर्म-विभागयोः | गुणा गुणेषु वर्तन्त इति मत्वा न सज्जते",
    "iast": "tattvavit tu mahābāho guṇa-karma-vibhāgayoḥ | guṇā guṇeṣu vartanta iti matvā na sajjate",
    "chapter_position": "Chapter 3 (Karma-Yoga (The Yoga of Action)), verse 28",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
