{
  "verse_id": "5.2",
  "mūla": {
    "devanāgarī": "संन्यासः कर्म-योगश् च निःश्रेयस-कराव् उभौ | तयोस् तु कर्म-संन्यासात् कर्म-योगो विशिष्यते",
    "iast": "saṃnyāsaḥ karma-yogaś ca niḥśreyasa-karāv ubhau | tayos tu karma-saṃnyāsāt karma-yogo viśiṣyate",
    "chapter_position": "Chapter 5 (Karma-Sannyāsa-Yoga (The Yoga of Renunciation)), verse 2",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "saṃnyāsas",
      "lemma": "saṃnyas",
      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "य कर्मयोगापेक्षया विशिष्टत्वविवक्षया विशिनष्टि केवलादिति",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "karma",
      "lemma": "karman",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "णां परित्यागः कर्मयोगश्च तेषामनुष्ठानं तौ उभौ",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "योगः च ज्ञानयोगशक्तस्य अपि उभौ निरपेक्षौ निःश्रेयसकरौ। तयोः तु कर्मसंन्यासाद् ज्ञानयोगात् कर्मयोगः एव विशिष्यते।कुत इत्य",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति निश्चयः इत्यादेश्च ब्राह्मे",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "योगस्थितिमुत्तरमाह सन्न्यासः कर्मयोगश्चेति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "योगमहं ब्रवीमि यतः पूर्वोक्तेन संन्यासेन विरोधः स्यात् अपितु देहात्माभिमानिनं त्वां बन्धुवधादिनिमित्तशोकमोहादिकृतमेनं सं",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "संन्यासादनधिकारिकृतात्कर्मयोगो विशिष्यते श्रेयानधिकारसंपादकत्वेन",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
        "कर्मयोग",
