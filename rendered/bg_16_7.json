            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ौचं वैदिककर्मयोग्यत्वं शास्त्रसिद्धम् तद् बाह्यम् आभ्यन्तरं",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ो निरूपयति -- प्रवृत्तिमित्यादिद्वादशभिः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "भिः। धर्मे प्रवृत्तिं? अधर्मान्निवृत्तिं च आसुरस्वभावा जना न जानन्ति। अतः शौचमाचारः सत्यं च तेषु नास्त्येव।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ेषणतया तानहमित्यतः प्राक्तनैर्द्वादशभिः श्लोकैर्विवृणोति -- प्रवृत्तिमिति",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
