      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "अरण्यनदीपुलिनगिरिगुहादीन् विविक्तान् देशान् सेवितुं शीलम् अस्य इति विविक्तसेवी? लघ्वाशी लघ्वशनशीलः -- विविक्तसेवालघ्वशन",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "सर्वैः ध्यानविरोधिभिः विविक्ते देशे वर्तमानः लघ्वाशी अत्यशनानशनरहितः? यतवाक्कायमानसः ध्यानाभिमुखीकृतकायवाङ्मनोवृत्तिः?",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "शुद्धदेशावस्थायी लध्वाशी मितभोजी एतैरुपायैर्यतवाक्कायमानसः संयतवाग्देहचित्तो भूत्वा नित्यं सर्वदा ध्यानेन यो योगो ब्रह्",
          "school": "bhakti",
          "weight": 0.8,
          "witnesses": [
            "sridhara"
          ]
        }
