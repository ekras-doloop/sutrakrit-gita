      "senses_attested_in_panel": [
        {
          "sense": "चिन्तयसि निश्चयं करोषि? मिथ्या एषः व्यवसायः निश्चयः ते तव यस्मात् प्रकृतिः क्षत्रियस्वभावः त्वां नियोक्ष्यति",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "एष ते स्वातन्त्र्य व्यवसायो मिथ्या भविष्यति",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। एष ते व्यवसायो मिथ्या व्यर्थ एव। तदा मदाज्ञाकारी प्रकृतिर्बहिरङ्गा शक्तिर्गौणस्वभावरूपा त्वां नियोक्ष्यत्येव।",
          "school": "śuddhādvaita",
          "weight": 0.8,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "यत् स मिथ्या निष्फल एष व्यवसायो निश्चयस्ते तव",
