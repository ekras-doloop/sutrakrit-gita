          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "ाङ्कः। सूर्यादीनामप्युपलक्षणमेतत्। प्रजापतिर्विराट् हिरण्यगर्भश्च। प्रपितामहश्च पितामहस्य हिरण्यगर्भस्यापि पिता च त्वम्।",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
