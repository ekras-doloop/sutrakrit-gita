      "lemma": "tva",
      "grammar": "accusative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "एव? पितामहादयः च",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। आङ्पूर्वाददो मन्। तत्वं च। इह देहे। सन्ततो भावो नित्या सत्ता। आङ्पूर्वात्तनोतेर्ङ्मन्। सदसद्भावात्मकं विश्वं त्वमेवेति",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "। अतस्ते तुभ्यं सहस्रकृत्वः सहस्रशो नमोऽस्तु। भूयोपि पुनरपि सहस्रकृत्वो नमो नम इति भक्तिश्रद्धाभरातिरेकेण नमस्कारेषु तृप",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "। यस्मादेवं सर्वदेवात्मकत्वात्त्वमेव सर्वैर्नमस्कार्योसि तस्मान्ममापि वराकस्य नमो नमस्ते तुभ्यमस्तु सहस्रकृत्वः। पुनश्च",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
