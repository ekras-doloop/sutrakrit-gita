      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "वेन मत्कीर्तनयतननमस्कारैः विना क्षणाणुमात्रे",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "नं कुर्वन्त इति श्रवणार्चनभक्तिर्निरूपिता",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "नं कुर्वन्तश्च केचिद्भक्त्या नमस्यन्तः प्रणमन्तश्चान्ये नित्ययुक्ता अनवरतमवहिताः सर्वे सेवन्ते भक्त्येति नित्ययुक्ता इति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "र वा वेदान्ताविरोधितर्कानुसंधानेनाप्रामाण्यशङ्कानास्कन्दितगुरूपदिष्टमत्स्वरूपावधारणाय यतमानाः",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "antas",
      "lemma": "anti",
      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [],
      "theme_lists": []
    },
    {
      "surface_form": "ca",
      "lemma": "ca",
      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "इन्द्रियोपसंहारशमदमदयाहिंसादिलक्षणैः धर्मैः प्रयतन्तश्च? दृढव्रताः दृढं स्थिरम् अचाल्यं व्रतं येषां ते दृढव्रताः नमस्यन",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ीनि मन्नामानि स्मृत्वा पुलकितसर्वाङ्गाः? हर्षगद्गदकण्ठाः श्रीरामनारायणकृष्णवासुदेवेत्येवमादीनि सततं कीर्तयन्तः तथा",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "्चिदानन्दा द्विविधाः स्वरूपात्मका धर्मात्मकाश्च",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "िन्मामुपासते सेवन्ते दृढानि व्रतानि नियमा येषां तादृशाः सन्तो यतन्तश्चेश्वरपूजादिषु इन्द्रियोपसंहारादिषु प्रयत्नं कुर्वन",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "्यते द्वाभ्याम् -- सततं सर्वदा ब्रह्मनिष्ठं गुरुमुपसृत्य वेदान्तवाक्यविचारेण गुरूपसदनेतरकाले",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "dṛḍha",
      "lemma": "dṛḍha",
      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "व्रताः दृढं स्थिरम् अचाल्यं व्रतं येषां ते दृढव्रताः नमस्यन्तश्च मां हृदयेशम् आत्मानं भक्त्या नित्ययुक्ताः सन्तः उपासते",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "संकल्पाः यतमानाः? भक्तिभारावनमितमनोबुद्ध्यभिमानपदद्वयकरद्वयशिरोभिः अष्टाङ्गैः अचिन्तितपांसुकर्द्दमशर्करादिके धरातले दण्ड",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ानि एकादशीजन्माष्टमीरामनवमीवामनद्बादशीनृसिंहजयन्तीसंज्ञकानि व्रतानि येषां ते दृढव्रताः? इति स्मरणमुक्तम्",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ानि व्रतानि नियमा येषां तादृशाः सन्तो यतन्तश्चेश्वरपूजादिषु इन्द्रियोपसंहारादिषु प्रयत्नं कुर्वन्तश्च केचिद्भक्त्या नमस्",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "व्रताः दृढानि प्रतिपक्षैश्चालयितुमशक्यानि अहिंसासत्यास्तेयब्रह्मचर्यापरिग्रहादीनि व्रतानि येषां ते",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "nam",
      "lemma": "na",
      "grammar": "accusative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "यथातन्नामस्मरणोद्भूतपुलकश्चेदिपुङ्गवः इति",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "। तादृशाधिभौतिकचिदंशभूतं तत्त्वनिष्ठं सुखम्। एवमेव यथातथान्तरतिरोभावो ज्ञेयः। एवं सति स्वरूपात्मकस्याधिदैविकाध्यात्मिकान",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "। अर्चनं वन्दनं दास्यं सख्यमात्मनिवेदनम् इति वन्दनसहचरितं श्रवणाद्यपि बोद्धवयम्। अर्चनं पादसेवनमित्यपि गुरुरूपे तस्मिन्स",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
