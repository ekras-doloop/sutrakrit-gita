  "mūla": {
    "devanāgarī": "प्रतिष्ठाप्य, किम् ? तत्रैकाग्रं मनः कृत्वा यत-चित्तेन्द्रिय-क्रियः | उपविश्यासने युञ्ज्याद् योगम् आत्म-विशुद्धये",
    "iast": "pratiṣṭhāpya, kim ? tatraikāgraṃ manaḥ kṛtvā yata-cittendriya-kriyaḥ | upaviśyāsane yuñjyād yogam ātma-viśuddhaye",
    "chapter_position": "Chapter 6 (Dhyāna-Yoga (The Yoga of Meditation)), verse 12",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
