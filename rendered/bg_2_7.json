      "senses_attested_in_panel": [
        {
          "sense": "ेति। योऽल्पां स्वल्पामपि स्वक्षतिं न क्षमते स कृपणस्तद्विधत्वादखिलोऽनात्मविदप्राप्तपरमपुरुषार्थतया कृपणो भवति।यो वा एतदक",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "म्। त्याज्यस्यापरित्यागोऽत्र कार्पण्यमित्येके दयाजनकदीनवृत्तिनिरतत्वमित्यपरे।भगवत्पादाम्बुजमुपससारेति शिष्यत्वप्रपन्नत्व",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति। तस्मात्कार्पण्यदोषोपहतस्वभावः। एतान्हत्वा कथं जीविष्याम इति कार्पण्यं दोषश्च स्वकुलक्षयकृतः ताभ्यामुपहतोऽभिभूतः स्व",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ं अनात्माध्यासवत्त्वं तन्निमित्तोऽस्मिञ्जन्मन्येत",
          "school": "advaita-bhakti",
