      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "ं प्रकृतं देहिनं न च्छिन्दन्ति शस्त्राणि निरवयवत्वात् न अवयवविभागं कुर्वन्ति",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "्यम्बुवायवः छेदनदहनक्लेदनशोषणानि आत्मानं प्रति कर्तुं न शक्नुवन्ति",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "िमित्तैश्चाविनाशिनोऽपि केनचिन्निमित्तविशेषेण स्यात् ककच्छेदादिवत् इत्यतो विशेषनिमित्तानि निषेधति नैनमिति",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "रस्यात्मनोऽविनाशित्वमेव सुग्रहणाय श्रावयति सार्द्धाभ्यां नैनमित्यादिना",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "्तीत्यनेनोक्तं वधसाधनाभावं दर्शयन्नविनाशित्वमात्मनः स्फुटीकरोति नैनमिति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "नु देहनाशे तदभ्यन्तरवर्तिन आत्मनः कुतो न विनाशो गृहदाहे तदन्तर्वर्तिपुरुषवदित्यत आह शस्त्राण्यस्यादीन्यतितीक्ष्णान्यप्ये",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
