      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "धृतराष्ट्र? संस्मृत्य संस्मृत्य प्रतिक्षणं संवादम् इमम् अद्भुतं केशवार्जुनयोः पुण्यम् इमं श्रवणेनापि पापहरं श्रुत्वा हृ",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "इत्यादिना श्लोकद्वयेन",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "निति। केशवार्जुनयोः संवादमिममद्भुतं स्मृत्वाऽहं मुहुर्महुर्हृष्यामि।",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "निति। हृष्यामि रोमाञ्चितो भवामि हर्षं प्राप्नोमीति वा। स्पष्टमन्यत्।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "निति। पुण्यं श्रवणेनापि सर्वपापहरं केशवार्जुनयोरिमं संवादमद्भुतं न केवलं श्रुतवानस्मि किंतु संस्मृत्य संस्मृत्य। संभ्रमे",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
