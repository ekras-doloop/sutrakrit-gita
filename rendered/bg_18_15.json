  "mūla": {
    "devanāgarī": "शरीरवाङ्मनोभिर्यत्कर्म प्रारभते नरः | न्याय्यं वा विपरीतं वा पञ्चैते तस्य हेतवः",
    "iast": "śarīravāṅmanobhiryatkarma prārabhate naraḥ | nyāyyaṃ vā viparītaṃ vā pañcaite tasya hetavaḥ",
    "chapter_position": "Chapter 18 (Mokṣa-Sannyāsa-Yoga (The Yoga of Liberation by Renunciation)), verse 15",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
