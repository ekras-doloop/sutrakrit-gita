      "grammar": "ablative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "मा जितः वशीकृतः आत्मा अन्तःकरणं यस्य सः जितात्मा? विगतस्पृहः विगता स्पृहा तृष्णा देहजीवितभोगेषु यस्मात् सः विगतस्पृहः? य",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "मा जितमनाः परमपुरुषकर्तृत्वानुसन्धानेन आत्मकर्तृत्वे विगतस्पृहः एवं त्यागाद् अनन्यत्वेन निर्णीतेन संन्यासेन युक्तः कर्म",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "मा विगतस्पृह इति योगसारं? भगवद्व्यतिरिक्ते स्पृहारहित इति वा भक्तिरुपादेयतयोक्ता",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "मा निरहंकारः? विगतस्पृहो विगता स्पृहा फलविषयेच्छा यस्मात्स एवंभूतेनस त्यागः सात्त्विको मत इत्येवं पूर्वोक्तेन कर्मासक्ति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "मा विषयेभ्यः प्रत्याहृत्य वशीकृतान्तःकरणः",
          "school": "advaita-bhakti",
