          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "िष्ठितस्य लक्षणमाह -- न द्वेष्टीति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "निष्ठां फलमाह -- न द्वेष्टीति",
