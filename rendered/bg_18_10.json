{
  "verse_id": "18.10",
  "mūla": {
    "devanāgarī": "न द्वेष्ट्यकुशलं कर्म कुशले नानुषज्जते | त्यागी सत्त्वसमाविष्टो मेधावी छिन्नसंशयः",
    "iast": "na dveṣṭyakuśalaṃ karma kuśale nānuṣajjate | tyāgī sattvasamāviṣṭo medhāvī chinnasaṃśayaḥ",
    "chapter_position": "Chapter 18 (Mokṣa-Sannyāsa-Yoga (The Yoga of Liberation by Renunciation)), verse 10",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "na",
      "lemma": "na",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "द्वेष्टि अकुशलम् अशोभनं काम्यं कर्म? शरीरारम्भद्वारेण संसारकारणम्? किमनेन इत्येवम्",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ः तत एव छिन्नसंशयः कर्मणि सङ्गफलकर्तृत्व त्यागी न द्वेष्टि अकुशलं कर्म कुशले च कर्मणि न अनुषज्जते।अकुशलं कर्म अनिष्टफलम्",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
