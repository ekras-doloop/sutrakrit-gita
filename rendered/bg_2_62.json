          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "पुंसः पुनरपि सङ्गः अतिप्रवृद्धो जायते",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "ध्यायतः पुरुषस्य तेषु सङ्ग आसक्तिर्भवति",
