{
  "verse_id": "1.2",
  "mūla": {
    "devanāgarī": "संजय उवाच दृष्ट्वा तु पाण्डवानीकं व्यूढं दुर्योधनस् तदा | आचार्यम् उपसंगम्य राजा वचनम् अब्रवीत्",
    "iast": "saṃjaya uvāca dṛṣṭvā tu pāṇḍavānīkaṃ vyūḍhaṃ duryodhanas tadā | ācāryam upasaṃgamya rājā vacanam abravīt",
    "chapter_position": "Chapter 1 (Arjuna-Viṣāda-Yoga (The Yoga of Arjuna's Despondency)), verse 2",
    "speaker": "Arjuna",
    "addressed_to": "Krishna"
  },
