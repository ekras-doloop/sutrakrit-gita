          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "य बन्धहेतुः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "यानादित्वं तद्धर्माधर्मप्रयुक्तत्वात्? कृत्स्नस्य जगतः जातस्य हर्षशोकभयसंप्रतिपत्तेः अन्यथा कृतहान्यकृताभ्यागमप्रसङ्गात्",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "sukha",
      "lemma": "sukhi",
      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "दुःखमोहप्रत्ययाकारपरिणतान् विद्धि जानीहि प्रकृतिसंभवान्? प्रकृतिः ईश्वरस्य विकारकारणशक्तिः त्रिगुणात्मिका माया? सा संभवो",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "दुःखानां भोक्तृत्वे",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "दुःखमोहा इति [शं.] कश्चित्",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
