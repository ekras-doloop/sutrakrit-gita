{
  "verse_id": "13.20",
  "mūla": {
    "devanāgarī": "कार्य-करण-कर्तृत्वे हेतुः प्रकृतिर् उच्यते | पुरुषः सुख-दुःखानां भोक्तृत्वे हेतुर् उच्यते",
    "iast": "kārya-karaṇa-kartṛtve hetuḥ prakṛtir ucyate | puruṣaḥ sukha-duḥkhānāṃ bhoktṛtve hetur ucyate",
    "chapter_position": "Chapter 13 (Kṣetra-Kṣetrajña-Vibhāga-Yoga (The Yoga of Distinction Between Field and Field-Knower)), verse 20",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "kārya",
      "lemma": "kṛ",
      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "मित्यादिना",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "ं शरीरं कारणानि ज्ञानकर्मात्मकानि समनस्कानि इन्द्रियाणि? तेषां क्रियाकारित्वे पुरुषाधिष्ठिता प्रकृतिः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ाकार्यगुणास्तिस्रो यतः स्वल्पोद्भवो जनौ इति माधुच्छन्दसशाखायाम्",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "कारणरूपेण प्रकृतिर्द्विविधा? कार्यरूपा जीवात्मोपाधिरविद्यायुक्ता कारणरूपा माया परमात्मनः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        }
      ],
      "theme_lists": [
        "कार्य"
      ]
    },
    {
      "surface_form": "karaṇa",
      "lemma": "kṛ",
      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "ानि। तथापि भूतानां विषयाणां च ग्रहणात्कथं तेषां प्रकृतिकार्यतेत्याशङ्क्याह -- देहेति। तथापि गुणानामिहाग्रहणान्न प्रकृतिक",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "ोपक्रमे विकारशब्दः क्षेत्रकार्यमात्रपरः?,तत्प्रत्यभिज्ञानाच्चात्रापि विकारशब्दस्तद्विषयः",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "kartṛtve",
      "lemma": "kartṛtva",
      "grammar": "locative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "न हेतुराश्रयो मूलप्रकृतिरित्यर्थः। उत्तरार्धस्य तात्पर्यमाह -- पुरुषश्चेति। तस्य परमात्मत्वं व्यवच्छिनत्ति -- जीव इति। त",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        }
      ],
      "theme_lists": []
    },
