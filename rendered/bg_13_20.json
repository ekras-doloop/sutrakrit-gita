      "senses_attested_in_panel": [
        {
          "sense": "यानादित्वकृतं बन्धहेतुत्वमाह -- पुरुष इति",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "य तु अधिष्ठातृत्वम्",
