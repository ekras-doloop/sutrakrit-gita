      "grammar": "Vibhakti.Sasthi singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "वृक्षस्य शाखा इव शाखाः प्रसृताः प्रगताः? गुणप्रवृद्धाः गुणैः सत्त्वरजस्तमोभिः प्रवृद्धाः स्थूलीकृताः उपादानभूतैः? विषयप",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "परब्रह्माधिगम उच्यते अत्र तु तच्छित्त्वा ततः परं परिमार्गितव्यमिति अतोऽस्यान्यार्थासम्भवात्संसारविषयत्वे सिद्धे तद्विदो",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "शाखा भूतान्यधश्च स्वापेक्षयाऽप्रकृष्टे शरीरादौ कार्ये चोर्ध्वं",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "शाखास्थानीयतया सुकृतिनो दुष्कृतिनश्चोच्यन्ते",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "संसारवृक्षस्य शाखाः",
