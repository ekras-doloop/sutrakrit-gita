            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "प्राप्नोति इत्यर्थः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ते। अन्यत्र महातात्पर्यविरोधः। उत्कर्षे हि महातात्पर्यम्। तथा हि सौकरायणश्रुतिः -- अवाच्योत्कर्षे महत्त्वासर्ववाचां सर्व",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "वम्भूतं पुरुषं देहेऽस्मिन्वर्त्तमानं उभयविधं वस्तुतोऽक्षरप्रभावं क्षेत्रज्ञं ब्रह्मांशभूतं चेतनं पुरुषं हंसस्वरूपभूतं स्",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "न तस्य स्वरूपमाह -- उपद्रष्टेति। अस्मिन्प्रकृतिकार्ये देहे च वर्तमानोऽपि पुरुषः परो भिन्न एव न तद्गुणैर्युज्यत इत्यर्थः।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "षु मध्ये बाह्यान्देहादीनपेक्ष्यात्यव्यवहितो द्रष्टात्मा पुरुष उपद्रष्टा",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
