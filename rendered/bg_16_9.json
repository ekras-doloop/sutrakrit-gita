{
  "verse_id": "16.9",
  "mūla": {
    "devanāgarī": "एतां दृष्टिम् अवष्टभ्य नष्टात्मानो ऽल्प-बुद्धयः | प्रभवन्त्य् उग्र-कर्माणः क्षयाय जगतो ऽहिताः",
    "iast": "etāṃ dṛṣṭim avaṣṭabhya naṣṭātmāno 'lpa-buddhayaḥ | prabhavanty ugra-karmāṇaḥ kṣayāya jagato 'hitāḥ",
    "chapter_position": "Chapter 16 (Daivāsura-Sampad-Vibhāga-Yoga (The Yoga of Distinction Between Divine and Demonic Endowments)), verse 9",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
