          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "दुःखसुखः दुःखसुखयोः समः चित्तः स्वस्थः स्वस्मिन् स्थितः स्वात्मैकप्रियत्वेन तद्व्यतिरिक्तपुत्रादिजन्ममरणादिसुखदुःखयोः सम",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "दुःखसुखः [14",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "ेति। गुणकार्येषु हर्षद्वेषशून्यतया स लक्ष्य इत्युक्ते समत्वं योगो हेतुरिति साङ्ख्ययोगसारभूतमर्थं स्मारयति। समे दुःखसुखे",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ेति। समे सुखदुःखे यस्य। यतः स्वस्थः स्वरूप एव स्थितः। अतएव समानि लोष्टाश्मकाञ्चनानि यस्य। तुल्ये प्रियाप्रिये सुखदुःखहेत",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "े दुःखसुखे द्वेषरागशून्यतयानात्मधर्मतयाऽनृततया",
          "school": "advaita-bhakti",
          "weight": 1.0,
