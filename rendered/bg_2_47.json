      "grammar": "nominative dual feminine noun",
      "senses_attested_in_panel": [
        {
          "sense": "तव। तत्र च कर्म कुर्वतः मा फलेषु अधिकारः अस्तु कर्मफलतृष्णा मा भूत् कदाचन कस्याञ्चिदप्यवस्थायामित्यर्थः। यदा कर्मफले तृ",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "कर्ममात्रे अधिकारः",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "ऽस्तीति",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "इति। कर्मैवोपादेयं तत्रैव तत्राधिकार इति। परन्तु तत्फलेषु मा कदाचनाधिकारोऽस्तु। उपदेशमुद्रामाह मा कर्मफलहेतुर्भूरिति। अ",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "त किं कर्मणेत्याशङ्क्य तद्वारयन्नाह कर्मण्येवेति",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "चेदात्मज्ञानमेव तर्हि संपाद्यं किं बह्वायासैः कर्मभिर्बहिरङ्गसाधनभूतैरित्याशङ्क्याह ते तवाशुद्धान्तःकरणस्य तात्त्विकज्ञ",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
        "फले सक्तो निबध्यते",
