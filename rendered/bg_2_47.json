{
  "verse_id": "2.47",
  "mūla": {
    "devanāgarī": "कर्मण्य् एवाधिकारस् ते मा फलेषु कदाचन | मा कर्म-फल-हेतुर् भूर् मा ते सङ्गो ऽस्त्व् अकर्मणि",
    "iast": "karmaṇy evādhikāras te mā phaleṣu kadācana | mā karma-phala-hetur bhūr mā te saṅgo 'stv akarmaṇi",
    "chapter_position": "Chapter 2 (Sāṅkhya-Yoga (The Yoga of Knowledge)), verse 47",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "karmaṇi",
      "lemma": "karman",
      "grammar": "locative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "प्रवर्तते तदा कर्मफलस्यैव जन्मनो",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "नित्यसत्त्वस्थस्य मुमुक्षोः ते कर्ममात्रे अधिकारः",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "प्रवर्तितुं शक्यन्ते अतस्तेषां कर्मण्यभिरुचिजननार्थं स्वर्गकामः आ.श्रौ.10",
          "school": "dvaita",
          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "च निषिद्धे परधर्मे सङ्गो मा तेऽस्तु।",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "कृते तत्फलं स्यादेव भोजने कृते तृप्तिवदित्याशङ्क्याह",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "। यदि फलं नेष्यते किं कर्मणा दुःखरूपेणेत्यकरणे तव प्रीतिर्माभूत्।",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
        "कर्मणि",
        "मा ते सङ्गोऽस्त्वकर्मणि"
      ]
    },
    {
      "surface_form": "eva",
      "lemma": "eva",
      "grammar": "vocative singular neuter noun",
      "senses_attested_in_panel": [
        {
          "sense": "ं मा कर्मफलहेतुः भूः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "म् अनुसन्धाय कर्म कुरु",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "ात्र। फलानि ह्यस्वातन्त्र्येण भवन्ति। नहि कर्मफलानि कर्माभावे यत्नतो भवन्ति। भवन्ति च काम्यकर्मिणो विपर्ययप्रयत्नेऽप्यवि",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "ं सति मम वेदोदन्वति किमुपादेयमित्याकाङ्क्षायामाह कर्मण्येवाधिकारस्ते इति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "फलं बन्धकं भविष्यतीति भयादकर्मणि कर्माकरणेऽपि तव सङ्गो निष्ठा मास्तु",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "adhikāras",
