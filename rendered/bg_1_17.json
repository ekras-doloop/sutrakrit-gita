          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "सञ्जय उवाच दुर्योधनः स्वयमेव भीमाभिरक्षितं पाण्डवानां बलम् आत्मीयं",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "पृथक्पृथक् शङ्खान् दध्मुः",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ेति। काश्यः काशिराजः। कथंभूतः। परमः श्रेष्ठ इष्वासो धनुर्यस्य सः।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "जन्यो देवदत्तः पौण्ड्रोऽनन्तविजयः सुधोषो मणिपुष्पकश्चेति शङ्खनामकथनम् परसैन्ये स्वस्वनामभिः प्रसिद्धा एतावन्तः शङ्खाः भव",
          "school": "advaita-bhakti",
