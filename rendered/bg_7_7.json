    {
      "surface_form": "parataram",
      "lemma": "paratara",
      "grammar": "accusative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "अन्यत् कारणान्तरं किञ्चित् नास्ति न विद्यते अहमेव जगत्कारणमित्यर्थः",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "इत्यत्र पूर्वोक्तस्यैवार्थस्य व्यतिरेकेण दृढीकरणमात्रपरत्वे मन्दप्रयोजनत्वम् अहं परतर इत्येवंरूपेण पूर्वमनुक्तेश्च तद्व",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "nān",
      "lemma": "na",
      "grammar": "accusative plural masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "यदस्ति परमित्यत्र",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "विता तथा सत्यन्यशब्दानन्वयप्रसङ्गात् अतोमत्तोऽन्यत्परतरं नास्ति इत्यन्वये अहमेव परतर इति फलितम् ततश्च समाभ्यधिकदरिद्रत्व",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "यदिति। अहमेव पर इत्यर्थः। किञ्चेदं सर्वं प्रोतमाश्रितं मयि तत्र यद्यत्स्वरूपमान्तरं बहिरिदं युष्मदाद्युपलभ्यमानत्वात्सत्",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "यत्र। सूत्रे मणिगणा इवेति दृष्टान्तस्तु ग्रथितत्वमात्रे नतु कारणत्वे। कनककुण्डलादिवदिति तु योग्यो दृष्टान्तः।",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
        "मत्तः परतरं नान्यत्"
