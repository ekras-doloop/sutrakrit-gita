{
  "verse_id": "7.7",
  "mūla": {
    "devanāgarī": "मत्तः परतरं नान्यत् किंचिद् अस्ति धनंजय | मयि सर्वम् इदं प्रोतं सूत्रे मणिगणा इव",
    "iast": "mattaḥ parataraṃ nānyat kiṃcid asti dhanaṃjaya | mayi sarvam idaṃ protaṃ sūtre maṇigaṇā iva",
    "chapter_position": "Chapter 7 (Jñāna-Vijñāna-Yoga (The Yoga of Knowledge and Realization)), verse 7",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
