      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "प्रभवान् संकल्पः प्रभवः येषां कामानां ते संकल्पप्रभवाः कामाः तान् त्यक्त्वा परित्यज्य सर्वान् अशेषतः निर्लेपेन",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "जाश्च इति द्विविधाः कामाः स्पर्शजाः शीतोष्णादयः सङ्कल्पजाः पुत्रपौत्रक्षेत्रादयः तत्र सङ्कल्पप्रभवाः स्वरूपेण",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति। संकल्पात्प्रभवो येषां तान्योगप्रतिकूलान्सर्वान्कामानशेषतः सवासनांस्त्यक्त्वा मनसैव विषयदोषदर्शिना सर्वतः प्रसरन्तमि",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ो दुष्टेष्वपि विषयेष्वशोभनत्वादर्शनेन शोभनाध्यासः",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
        "संकल्प"
