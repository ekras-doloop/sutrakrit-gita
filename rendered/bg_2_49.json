      "grammar": "instrumental singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "अतिविप्रकर्षेण अत्यन्तमेव हि अवरम् अधमं निकृष्टं कर्म फलार्थिना क्रियमाणं बुद्धियोगात् समत्वबुद्धियुक्तात् कर्मणः जन्मम",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "अवरम्",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "ेति। बुद्धियोगाज्ज्ञानलक्षणादुपायात्। दूरेणातीव। अतो बुद्धौ शरणं ज्ञाने स्थितिम्। फलं कर्म कृतौ हेतुर्येषां ते फलहेतवः।",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "ेति। बुद्ध्या व्यवसायात्मिकया कृतः कर्मयोगो बुद्धियोगः। बुद्धिसाधनभूतो वा तस्मात्सकाशादन्यत्काम्यं कर्म दूरेणावरमत्यन्तम",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ातिविप्रकर्षेणावरमधमं कर्म फलाभिसंधिना क्रियमाणं जन्ममरणहेतुभूतं अथवा परमात्मबुद्धियोगाद्दूरेणावरं सर्वमपि कर्म",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
