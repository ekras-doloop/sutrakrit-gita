      "senses_attested_in_panel": [
        {
          "sense": "यस्मात् समाचरन् ईश्वरार्थं कर्म कुर्वन् परं मोक्षम् आप्नोति पूरुषः सत्त्वशुद्धिद्वारेण इत्यर्थः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "इत्यादिनोच्यत इत्यभिप्रायेणाह असक्त इति",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "तं नित्यं नैमित्तिकं तदाचरन् असक्तः पुरुषो ब्रह्मविदाप्नोति परं पदम्",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "तः सन्कार्यमवश्यकर्तव्यतया विहितं नित्यनैमित्तिकं कर्म सम्यगाचर",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "तः। सततं सर्वदा नतु कदाचित् कार्यमवश्यकर्तव्यं यावज्जीवादिश्रुतिचोदितम्तमेतं वेदानुवचनेन ब्राह्मणा विविदिषन्ति यज्ञेन दा",
          "school": "advaita-bhakti",
          "weight": 1.0,
