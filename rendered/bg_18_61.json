      "senses_attested_in_panel": [
        {
          "sense": "ढानि यन्त्राणि आरूढानि अधिष्ठितानि इव -- इति इवशब्दः अत्र द्रष्टव्यः -- यथा दारुकृतपुरुषादीनि यन्त्रारूढानि",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ढानि सर्वभूतानि मायया भ्रामयन् स्वेन",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "पेण मया सर्वं भूतजातं प्राकृतकर्मानुगुणलीलया प्रकृत्यनुवर्त्तने नियमितं भवतीति ब्रह्मसूत्रसिद्धान्तमाह -- ईश्वर इति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ढानि कृत्रिमाणि भूतानि सूत्रधारो लोके भ्रामयति तद्वदित्यर्थः",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "यतेऽपि वा",
