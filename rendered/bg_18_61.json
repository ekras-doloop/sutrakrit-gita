        {
          "sense": "स्थितिं लभते",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। कथं किं कुर्वन् तिष्ठति यन्त्रारूढानि सर्वभूतानि मायया भ्रामयन् स्वेन एव निर्मितं देहेन्द्रियावस्थप्रकृत्याख्यं यन्त्र",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "। तत्रान्तर्यामिस्वरूपेण स्थितोऽपि निर्लेप इत्याशयेनेश्वर इत्युक्तम्। उपाधिस्थाने स्थितस्य तदसंस्पृष्टत्वमीश्वरत्वादित्य",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "। किं कुर्वन् सर्वाणि भूतानि मायया निजशक्त्या भ्रामयन् तत्तत्कर्मसु प्रवर्तयन् यथा दारुयन्त्रमारूढानि कृत्रिमाणि भूतानि",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "सर्वव्यापकोऽपि तत्राभिव्यज्यते सप्तद्वीपाधिपतिरिव राम उत्तरकोसलेषु",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
