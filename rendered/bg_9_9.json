      "senses_attested_in_panel": [
        {
          "sense": "च माम् ईश्वरं तानि भूतग्रामस्य विषमसर्गनिमित्तानि कर्माणि निबध्नन्ति धनंजय। तत्र कर्मणां असंबन्धित्वे कारणमाह -- उदासीन",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "च तानि विषमसृष्ट्यादीनि कर्माणि मां निबध्नन्ति मयि नैर्घृण्यादिकं न आपादयन्ति? यतः क्षेत्रज्ञानां पूर्वकृत्यानि एव कर्म",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
