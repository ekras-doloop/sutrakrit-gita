          ]
        },
        {
          "sense": "तदनुभवहेतुभूते पुण्ये क्षीणे पुनरपि मर्त्यलोकं विशन्ति",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "भोगप्रापके पुण्ये क्षीणे सति,मर्त्यलोकं विशन्ति",
