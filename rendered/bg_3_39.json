      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "ं तृष्णाकाले मित्रमिव पश्यन् तत्कार्ये दुःखे प्राप्ते जानाति तृष्णया अहं दुःखित्वमापादितः इति न पूर्वमेव",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "कारेण विषयव्यामोहजननेन नित्यवैरिणा आवृतं दुष्पूरेण पूर्त्यनर्हविषयेण अनलेन",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेनावृतं ज्ञानिनोऽपि किम्वल्पज्ञानिनः",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "ः सुखहेतुरेव परिणामे तु वैरितां प्रपद्यते",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ेनावृतं तथाप्यापाततः सुखहेतुत्वादुपादेयः स्यादित्यत आह ज्ञानिनो नित्यवैरिणा",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
        "काम अछत सुख सपनेहुँ नाहीं",
