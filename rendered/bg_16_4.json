    {
      "surface_form": "ca",
      "lemma": "ca",
      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "। पारुष्यमेव च परुषवचनम् -- यथा काणम् चक्षुष्मान् विरूपम् रूपवान् हीनाभिजनम् उत्तमाभिजनः इत्यादि। अज्ञानं च अविवेकज्ञानं",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "स्वविद्याभिजनाननुगुणोऽभिमानः",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "कारैः पूर्वप्रतियोगिनो गृह्यन्ते स्पष्टमन्यत्",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ित्तस्योत्सेकः? अभिमानो व्याख्यातः? क्रोधः प्रसिद्धः? पारुष्यं निष्ठुरत्वम्? अज्ञानमविवेकः? आसुरीमित्युपलक्षणम्",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "वा असुराश्चोभये प्राजापत्याः तं स्पृधिरे ततोऽसुरा अतिमानेनैव कस्मिन्नु वयं जुहुवामेति स्वेष्वेवास्येषु जुह्वतश्चेरुस्ते",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
