      "grammar": "1st person singular present indicative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "अस्मिन् शास्त्रार्थानुष्ठानाधिकृतानां त्रैवर्णिकानां द्विविधा द्विप्रकारा निष्ठा स्थितिः अनुष्ठेयतात्पर्यं पुरा पूर्वं",
          "school": "advaita",
          "weight": 0.8,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "विचित्राधिकारिसंपूर्णे द्विविधा निष्ठा ज्ञानकर्मविषया यथाधिकारम् असंकीर्णा",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "शुद्धाशुद्धान्तःकरणभेदेन द्विविधे जने द्विविधा द्विप्रकारा निष्ठा स्थितिर्ज्ञानपरता कर्मपरता",
          "school": "advaita-bhakti",
          "weight": 0.8,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
