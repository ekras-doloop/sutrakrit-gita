          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "सह कर्म कुर्वन्त एवेत्यर्थः",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "ज्ञानसंसिद्धिं वाऽऽस्थिता इति",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "रब्धशरीरस्त्वं विद्वानपि जनकादिवत्प्रारब्धकर्मबलेन लोकसंग्रहार्थं कर्म कर्तुं योग्यो भवसि नतु त्युक्तं ब्राह्मणजन्मालाभा",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": [
