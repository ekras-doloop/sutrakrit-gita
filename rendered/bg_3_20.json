      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "यस्मात् पूर्वे क्षत्रियाः विद्वांसः संसिद्धिं मोक्षं गन्तुम् आस्थिताः प्रवृत्ताः",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "जनकादयो राजर्षयो ज्ञानिनाम् अग्रेसराः कर्मयोगेन",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "तेषां ज्ञानित्वं भारतादिषु",
          "school": "dvaita",
          "weight": 0.5,
          "witnesses": [
            "madhva",
            "jayatirtha"
          ]
        },
        {
          "sense": "तः। तथाच न केवलं ज्ञानिन एव कर्मानधिकारः किंतु ज्ञानार्थिनोऽपि विरक्तस्य। तथाच मयापि विरक्तेन ज्ञानार्थिना कर्माणि हेयान",
          "school": "advaita-bhakti",
