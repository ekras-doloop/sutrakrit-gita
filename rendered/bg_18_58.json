        {
          "sense": "अतिक्रमिष्यसि",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। अथ त्वम् अहंकाराद् अहम् एव कृत्याकृत्यविषयं सर्वं जानामि इति भावात् मदुक्तं न श्रोष्यसि चेद् विनङ्क्ष्यसि नष्टो भविष्य",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। अथ चेदिति उपपत्तिः। मतान्तरस्थितिमाशङ्क्य न श्रोष्यसि तर्हि नष्टो भविष्यसि? प्राकृत इव।",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "। विपक्षे दोषमाह -- अथ चेद्यदि पुनस्त्वमहकाराज्ज्ञातृत्वाभिमानान्मदुक्तमेतन्न श्रोष्यसि तर्हि विनङ्क्ष्यसि पुरुषार्थाद्भ",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        }
      ],
      "theme_lists": []
    },
    {
      "surface_form": "atha",
      "lemma": "atha",
      "grammar": "nominative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "चेत् यदि त्वं मदुक्तम् अहंकारात् पण्डितः अहम् इति न श्रोष्यसि न ग्रहीष्यसि? ततः त्वं विनङ्क्ष्यसि विनाशं गमिष्यसि",
