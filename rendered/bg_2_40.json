      "senses_attested_in_panel": [
        {
          "sense": "ेति। प्रतीकत्वेनोपात्तस्य नकारस्य पुनरन्वयानुगुणत्वेन नास्तीत्यनुवादः। यत्तु कर्मानुष्ठानस्यानैकान्तिकफलत्वेनाकिंचित्करत",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "anandgiri"
          ]
        },
        {
          "sense": "ाभिक्रम इत्येतन्न सङ्गच्छत इत्यत्राह वक्ष्यमाणेति",
