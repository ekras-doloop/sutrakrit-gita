          "weight": 1.0,
          "witnesses": [
            "jayatirtha"
          ]
        },
        {
          "sense": "। सर्वगतस्य नित्यज्ञानानन्दस्वभावस्यात्मनोऽलौकिकत्वादैन्द्रजालिकवदघटमानं पश्यन्निव विस्मयेन पश्यति असंभावनाभिभूतत्वात्।",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "। शास्त्राचार्योपदेशाभ्यामाविद्यकसर्वद्वैतनिषेधेन परमात्मस्वरूपमात्राकारायां वेदान्तमहावाक्यजन्यायां सर्वसुकृतफलभूतायामन",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
