      "senses_attested_in_panel": [
        {
          "sense": "इदानीं ते तव दिव्याः दिवि भवाः आत्मविभूतयः आत्मनः मम विभूतयः याः ताः कथयिष्यामि इत्येतत्",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ेति। ते अनसूयत्वप्रीयमाणत्वातृप्तत्वादिगुणपूर्णायेति भावः। गुणत्वादिप्रतियोगिकशेषित्वादिप्राधान्यविवक्षायां वक्ष्यमाणसमस",
          "school": "viśiṣṭādvaita",
          "weight": 1.0,
          "witnesses": [
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति। अनुकम्पा सम्बोधने। या दिव्या ममात्मविभूतयस्ता वक्ष्यामि। तत्रापि प्राधान्यतः? न तु सामस्त्येन अनन्तत्वात्तदाह -- ना",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ेति। हन्तेत्यनुकम्पासंबोधनम्। दिव्या या मम विभूतयस्ताः प्राधान्येन तुभ्यं कथयिष्यामि। यतोऽवान्तरस्य विभूतिविस्तरस्य मदीय",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
