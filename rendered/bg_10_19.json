            "shankara"
          ]
        },
        {
          "sense": "। प्राधान्यशब्देन उत्कर्षो विवक्षितः?पुरोधसां च मुख्यं माम् (गीता 10।24) इति हि वक्ष्यते। जगति उत्कृष्टाः काश्चन विभूतीः",
          "school": "viśiṣṭādvaita",
          "weight": 0.8,
          "witnesses": [
            "ramanuja"
          ]
        },
        {
          "sense": "। यतोऽवान्तरस्य विभूतिविस्तरस्य मदीयस्यान्तो नास्त्यतः प्रधानभूताः कतिचिद्वर्णयिष्यामि।",
          "school": "bhakti",
          "weight": 0.8,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "प्राधान्यतस्ता विभूतीर्या दिव्या हि प्रसिद्धा आत्मनो ममासाधारणा विभूतयः",
          "school": "advaita-bhakti",
          "weight": 0.8,
