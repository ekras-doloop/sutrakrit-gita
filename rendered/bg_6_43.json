        {
          "sense": "एव पौर्वदैहिकं योगविषयं बुद्धिसंयोगं लभते। ततः सुप्तप्रबुद्धवद् भूयः संसिद्धौ यतते। यथा न अन्तरायहतो भवति तथा यतते।",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "। तत्र चतुर्थी भूमिं प्राप्तस्य मृतस्य जीवन्मुक्त्यभावेऽपि विदेहकैवल्यं प्रति नास्त्येव संशयः। तदुत्तरभूमित्रयं प्राप्तस",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
