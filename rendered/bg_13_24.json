      "grammar": "vocative singular masculine noun",
      "senses_attested_in_panel": [
        {
          "sense": "यथोक्ताम् अविद्यालक्षणां गुणैः स्वविकारैः सह निवर्तिताम् अभावम् आपादितां विद्यया? सर्वथा सर्वप्रकारेण वर्तमानोऽपि सः भू",
          "school": "advaita",
          "weight": 0.5,
          "witnesses": [
            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "ित् निष्पन्नयोगा आत्मनि शरीरे अवस्थितम् आत्मानम् आत्मना मनसा ध्यानेन भक्तियोगेन पश्यन्ति",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "गुणैः सुखदुःखादिपरिणामैः सहितां यो वेत्ति? स पुरुषः सर्वथा विधिमतिलङ्घ्य वर्तमानोऽपि पुनर्नाभिजायते",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "यो यत्प्रभावश्चेति व्याख्यातं? इदानीं यज्ज्ञात्वाऽमृतमश्नुत इत्युक्तमुपसंहरति -- य एवमिति। य एवमुक्तेन प्रकारेण वेत्ति",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
