            "shankara",
            "anandgiri"
          ]
        },
        {
          "sense": "मोहाः -- निर्गतानात्मात्माभिमानरूपमोहाः? जितसङ्गदोषाः -- जितगुणमयभोगसङ्गाख्यदोषाः अध्यात्मनित्याः -- आत्मनि यद् ज्ञानं त",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "ेति। मानमोहराहित्यं सङ्गदोषराहित्यं अध्यात्मज्ञाननित्यत्वं निवृत्तकामत्वं सुखदुःखादिद्वन्द्वरहितत्वं चेति। साधनसम्पन्नास",
          "school": "śuddhādvaita",
          "weight": 1.0,
          "witnesses": [
            "vallabha"
          ]
        },
        {
          "sense": "ेति। निर्गतौ मानमोहावहंकारमिथ्याभिनिवेशौ येभ्यस्ते? जितः पुत्रादिसङ्गरूपो दोषो यैस्ते? अध्यात्मे आत्मज्ञाने नित्याः परिन",
          "school": "bhakti",
          "weight": 1.0,
          "witnesses": [
            "sridhara"
          ]
        },
        {
          "sense": "ेति। मानोऽहंकारो गर्वो मोहस्त्वविवेको विपर्ययो वा ताभ्यां निष्क्रान्ता निर्मानमोहास्तौ निर्गतौ येभ्यस्ते वा। तथाहंकारावि",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
