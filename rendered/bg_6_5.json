{
  "verse_id": "6.5",
  "mūla": {
    "devanāgarī": "उद्धरेद् आत्मनात्मानं नात्मानम् अवसादयेत् | आत्मैव ह्य् आत्मनो बन्धुर् आत्मैव रिपुर् आत्मनः",
    "iast": "uddhared ātmanātmānaṃ nātmānam avasādayet | ātmaiva hy ātmano bandhur ātmaiva ripur ātmanaḥ",
    "chapter_position": "Chapter 6 (Dhyāna-Yoga (The Yoga of Meditation)), verse 5",
    "speaker": "Krishna",
    "addressed_to": "Arjuna"
  },
  "word_by_word": [
    {
      "surface_form": "uddharet",
      "lemma": "uddhṛ",
      "grammar": "3rd person singular optative active verb",
      "senses_attested_in_panel": [
        {
          "sense": "संसारसागरे निमग्नम् आत्मना आत्मानं ततः उत् ऊर्ध्वं हरेत् उद्धरेत् योगारूढतामापादयेदित्यर्थः",
          "school": "advaita",
          "weight": 1.0,
          "witnesses": [
            "shankara"
          ]
        },
        {
          "sense": "। तद्विपरीतेन मनसा आत्मानं न अवसादयेत्। आत्मा एव मन एव हि आत्मनो बन्धुः तद् एव आत्मनो रिपुः।",
          "school": "viśiṣṭādvaita",
          "weight": 0.5,
          "witnesses": [
            "ramanuja",
            "vedantadeshika"
          ]
        },
        {
          "sense": "उत् ऊर्ध्वं हरेत्",
          "school": "advaita-bhakti",
          "weight": 1.0,
          "witnesses": [
            "madhusudan"
          ]
        }
      ],
      "theme_lists": []
    },
