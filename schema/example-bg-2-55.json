  "doctrinal_projections": {
    "advaita": {
      "reading_summary": "The verse defines sthita-prajña as the person who has abandoned desires by realizing the non-dual self; satisfaction-in-self means the natural state of the realized self resting in itself with no second to satisfy or be satisfied by. The abandonment is the spontaneous result of jñāna; it is not a volitional disciplinary act of suppressing desires but the recognition that what one had taken to be desires belongs to a self that is not the realized ātman.",
      "key_cross_references": ["2.59", "2.61", "5.18", "5.19", "5.20", "5.21"],
      "witness_passages": ["Śaṅkara on 2.55", "Anandagiri ṭīkā ad loc"],
      "score": 0.83
    },
    "viśiṣṭādvaita": {
      "reading_summary": "The verse defines sthita-prajña as the devotee whose mind has stably turned away from sense-objects toward the personal Lord. Satisfaction-in-self means satisfaction of the self in the Lord whose attribute the self is; the self does not become identical with the Lord (as in Advaita) but is stably composed in its devotional relationship to the Lord. The abandonment of desires is preparatory to the devotional state, not its automatic consequence.",
      "key_cross_references": ["6.30", "6.31", "12.13", "12.14", "12.15", "12.16", "12.17", "12.18", "12.19", "18.65", "18.66"],
      "witness_passages": ["Vedantadeshika Tātparya-candrikā 2.55", "Rāmānuja gloss ad loc"],
      "score": 0.79
    },
    "dvaita": {
      "reading_summary": "The verse defines sthita-prajña as the discriminating soul who has properly understood its eternal distinction from the Lord and from prakṛti. Abandoning desires here is preparatory to liberation as eternal participation in service from preserved individuality; the soul does not merge into the Lord (as in Advaita) and does not become a fully-attribute-status entity (as in Viśiṣṭādvaita) but maintains its eternal substance-distinction while engaging in devotional service.",
      "key_cross_references": ["18.62", "18.66"],
      "witness_passages": ["Madhva Gītā-bhāṣya 2.55", "Jayatīrtha ṭīkā ad loc"],
      "score": 0.61
    }
  },
